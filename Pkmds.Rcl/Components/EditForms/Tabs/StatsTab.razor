@inherits BasePkmdsComponent

@if (Pokemon is not null &&
     AppState is
     {
         SaveFile:
         {
             Context: not
             (EntityContext.None or
             EntityContext.SplitInvalid or
             EntityContext.MaxInvalid),
             Generation: var saveGeneration
         },
         SelectedSlotsAreValid: true
     })
{
    <MudGrid>

        <MudItem xs="12">
            <MudStack>
                <MudSwitch T="@bool"
                           Value="@ShowStatsChart"
                           Color="@Color.Primary"
                           Label="Show Stats Chart"
                           ValueChanged="@(v => { Haptics.Tap(); ShowStatsChart = v; })"/>
                @if (ShowStatsChart)
                {
                    <MudPaper Class="pa-1">
                        <StatsChart
                            Pokemon="@Pokemon"/>
                    </MudPaper>
                }
            </MudStack>
        </MudItem>

        <MudItem xs="3">
            <MudStack>
                <MudText>
                    Base
                </MudText>

                <MudNumericField Label="HP"
                                 title="HP Base Stat"
                                 Variant="@Variant.Outlined"
                                 Value="@Pokemon.PersonalInfo.HP"
                                 ReadOnly
                                 HideSpinButtons/>

                <MudNumericField Label="Atk"
                                 Class="@GetStatClass(Stats.Attack)"
                                 title="Attack Base Stat"
                                 Variant="@Variant.Outlined"
                                 Value="@Pokemon.PersonalInfo.ATK"
                                 ReadOnly
                                 HideSpinButtons/>

                <MudNumericField Label="Def"
                                 Class="@GetStatClass(Stats.Defense)"
                                 title="Defense Base Stat"
                                 Variant="@Variant.Outlined"
                                 Value="@Pokemon.PersonalInfo.DEF"
                                 ReadOnly
                                 HideSpinButtons/>

                @if (saveGeneration == 1 && Pokemon is PK1 pk1)
                {
                    <MudNumericField Label="Spe"
                                     title="Speed Base Stat"
                                     Variant="@Variant.Outlined"
                                     Value="@pk1.PersonalInfo.SPE"
                                     ReadOnly
                                     HideSpinButtons/>

                    <MudNumericField Label="Spc"
                                     title="Special Base Stat"
                                     Variant="@Variant.Outlined"
                                     Value="@pk1.PersonalInfo.SPC"
                                     ReadOnly
                                     HideSpinButtons/>
                }
                else
                {
                    <MudNumericField Label="Spa"
                                     Class="@GetStatClass(Stats.SpecialAttack)"
                                     title="Special Attack Base Stat"
                                     Variant="@Variant.Outlined"
                                     Value="@Pokemon.PersonalInfo.SPA"
                                     ReadOnly
                                     HideSpinButtons/>

                    <MudNumericField Label="Spd"
                                     Class="@GetStatClass(Stats.SpecialDefense)"
                                     title="Special Defense Base Stat"
                                     Variant="@Variant.Outlined"
                                     Value="@Pokemon.PersonalInfo.SPD"
                                     ReadOnly
                                     HideSpinButtons/>

                    <MudNumericField Label="Spe"
                                     Class="@GetStatClass(Stats.Speed)"
                                     title="Speed Base Stat"
                                     Variant="@Variant.Outlined"
                                     Value="@Pokemon.PersonalInfo.SPE"
                                     ReadOnly
                                     HideSpinButtons/>

                    <MudNumericField Label="Sum"
                                     title="Base Stat Total"
                                     Variant="@Variant.Outlined"
                                     Value="@Pokemon.PersonalInfo.GetBaseStatTotal()"
                                     ReadOnly
                                     HideSpinButtons/>
                }

            </MudStack>
        </MudItem>

        <MudItem xs="3">
            <MudStack>
                <MudStack Row
                          AlignItems="@AlignItems.Center"
                          Spacing="1">
                    <MudText>IVs</MudText>
                    <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.IVs)"
                                     Analysis="@Analysis"
                                     Title="IVs"/>
                </MudStack>

                <MudNumericField T="@int"
                                 Label="HP"
                                 Class="@GetIvFieldClass(Pokemon.IV_HP, Stats.Hp)"
                                 title="HP IV"
                                 Variant="@Variant.Outlined"
                                 Min="@int.MinValue"
                                 Max="@(saveGeneration == 1 && Pokemon is PK1
                                          ? 15
                                          : 31)"
                                 Value="@Pokemon.IV_HP"
                                 ValueChanged="@(newValue => OnSetIv(Stats.Hp, newValue))"
                                 For="@(() => Pokemon.IV_HP)"
                                 ReadOnly="@(saveGeneration == 1 && Pokemon is PK1)"
                                 HideSpinButtons="@(saveGeneration == 1 && Pokemon is PK1)"/>

                <MudNumericField T="@int"
                                 Label="Atk"
                                 Class="@GetIvFieldClass(Pokemon.IV_ATK, Stats.Attack)"
                                 title="Attack IV"
                                 Variant="@Variant.Outlined"
                                 Min="@int.MinValue"
                                 Max="@(saveGeneration == 1 && Pokemon is PK1
                                          ? 15
                                          : 31)"
                                 Value="@Pokemon.IV_ATK"
                                 ValueChanged="@(newValue => OnSetIv(Stats.Attack, newValue))"
                                 For="@(() => Pokemon.IV_ATK)"/>

                <MudNumericField T="@int"
                                 Label="Def"
                                 Class="@GetIvFieldClass(Pokemon.IV_DEF, Stats.Defense)"
                                 title="Defense IV"
                                 Variant="@Variant.Outlined"
                                 Min="@int.MinValue"
                                 Max="@(saveGeneration == 1 && Pokemon is PK1
                                          ? 15
                                          : 31)"
                                 Value="@Pokemon.IV_DEF"
                                 ValueChanged="@(newValue => OnSetIv(Stats.Defense, newValue))"
                                 For="@(() => Pokemon.IV_DEF)"/>


                @if (saveGeneration == 1 && Pokemon is PK1 pk1)
                {
                    <MudNumericField T="@int"
                                     Label="Spe"
                                     Class="@GetIvFieldClass(pk1.IV_SPE, Stats.Speed)"
                                     title="Speed IV"
                                     Variant="@Variant.Outlined"
                                     Min="@int.MinValue"
                                     Max="15"
                                     Value="@pk1.IV_SPE"
                                     ValueChanged="@(newValue => OnSetDv(Stats.Speed, newValue))"
                                     For="@(() => pk1.IV_SPE)"/>

                    <MudNumericField T="@int"
                                     Label="Spc"
                                     Class="@GetIvFieldClass(pk1.IV_SPC, Stats.Special)"
                                     title="Special IV"
                                     Variant="@Variant.Outlined"
                                     Min="@int.MinValue"
                                     Max="15"
                                     Value="@pk1.IV_SPC"
                                     ValueChanged="@(newValue => OnSetDv(Stats.Special, newValue))"
                                     For="@(() => pk1.IV_SPC)"/>
                }
                else
                {
                    <MudNumericField T="@int"
                                     Label="Spa"
                                     Class="@GetIvFieldClass(Pokemon.IV_SPA, Stats.SpecialAttack)"
                                     title="Special Attack IV"
                                     Variant="@Variant.Outlined"
                                     Min="@int.MinValue"
                                     Max="@(saveGeneration == 1 && Pokemon is PK1
                                              ? 15
                                              : 31)"
                                     Value="@Pokemon.IV_SPA"
                                     ValueChanged="@(newValue => OnSetIv(Stats.SpecialAttack, newValue))"
                                     For="@(() => Pokemon.IV_SPA)"/>

                    <MudNumericField T="@int"
                                     Label="Spd"
                                     Class="@GetIvFieldClass(Pokemon.IV_SPD, Stats.SpecialDefense)"
                                     title="Special Defense IV"
                                     Variant="@Variant.Outlined"
                                     Min="@int.MinValue"
                                     Max="@(saveGeneration == 1 && Pokemon is PK1
                                              ? 15
                                              : 31)"
                                     Value="@Pokemon.IV_SPD"
                                     ValueChanged="@(newValue => OnSetIv(Stats.SpecialDefense, newValue))"
                                     For="@(() => Pokemon.IV_SPD)"/>

                    <MudNumericField T="@int"
                                     Label="Spe"
                                     Class="@GetIvFieldClass(Pokemon.IV_SPE, Stats.Speed)"
                                     title="Speed IV"
                                     Variant="@Variant.Outlined"
                                     Min="@int.MinValue"
                                     Max="@(saveGeneration == 1 && Pokemon is PK1
                                              ? 15
                                              : 31)"
                                     Value="@Pokemon.IV_SPE"
                                     ValueChanged="@(newValue => OnSetIv(Stats.Speed, newValue))"
                                     For="@(() => Pokemon.IV_SPE)"/>

                    <MudNumericField Label="Sum"
                                     title="IVs Total"
                                     Variant="@Variant.Outlined"
                                     Value="@Pokemon.IVTotal"
                                     For="@(() => Pokemon.IVTotal)"
                                     ReadOnly
                                     HideSpinButtons/>
                }

            </MudStack>
        </MudItem>

        @if (Pokemon is IAwakened aPkm)
        {
            <MudItem xs="3">
                <MudStack>
                    <MudStack Row
                              AlignItems="@AlignItems.Center"
                              Spacing="1">
                        <MudText>AVs</MudText>
                        <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.AVs)"
                                         Analysis="@Analysis"
                                         Title="AVs"/>
                    </MudStack>

                    <MudNumericField Label="HP"
                                     T="@byte"
                                     title="HP AV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@AwakeningUtil.AwakeningMax"
                                     @bind-Value="@aPkm.AV_HP"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => aPkm.AV_HP)"/>

                    <MudNumericField Label="Atk"
                                     Class="@GetStatClass(Stats.Attack)"
                                     T="@byte"
                                     title="Attack AV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@AwakeningUtil.AwakeningMax"
                                     @bind-Value="@aPkm.AV_ATK"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => aPkm.AV_ATK)"/>

                    <MudNumericField Label="Def"
                                     Class="@GetStatClass(Stats.Defense)"
                                     T="@byte"
                                     title="Defense AV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@AwakeningUtil.AwakeningMax"
                                     @bind-Value="@aPkm.AV_DEF"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => aPkm.AV_DEF)"/>

                    <MudNumericField Label="Spa"
                                     Class="@GetStatClass(Stats.SpecialAttack)"
                                     T="@byte"
                                     title="Special Attack AV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@AwakeningUtil.AwakeningMax"
                                     @bind-Value="@aPkm.AV_SPA"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => aPkm.AV_SPA)"/>

                    <MudNumericField Label="Spd"
                                     Class="@GetStatClass(Stats.SpecialDefense)"
                                     T="@byte"
                                     title="Special Defense AV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@AwakeningUtil.AwakeningMax"
                                     @bind-Value="@aPkm.AV_SPD"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => aPkm.AV_SPD)"/>

                    <MudNumericField Label="Spe"
                                     Class="@GetStatClass(Stats.Speed)"
                                     T="@byte"
                                     title="Speed AV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@AwakeningUtil.AwakeningMax"
                                     @bind-Value="@aPkm.AV_SPE"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => aPkm.AV_SPE)"/>

                    <MudNumericField Label="Sum"
                                     title="AVs Total"
                                     Variant="@Variant.Outlined"
                                     Value="@aPkm.AwakeningSum()"
                                     ReadOnly
                                     HideSpinButtons/>

                </MudStack>
            </MudItem>
        }
        else if (Pokemon is IGanbaru gPkm)
        {
            <MudItem xs="3">
                <MudStack>
                    <MudStack Row
                              AlignItems="@AlignItems.Center"
                              Spacing="1">
                        <MudText>GVs</MudText>
                        <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.GVs)"
                                         Analysis="@Analysis"
                                         Title="GVs"/>
                    </MudStack>

                    <MudNumericField Label="HP"
                                     T="@byte"
                                     title="HP GV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@Pokemon.GetMaxGanbaru(0)"
                                     @bind-Value="@gPkm.GV_HP"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => gPkm.GV_HP)"/>

                    <MudNumericField Label="Atk"
                                     Class="@GetStatClass(Stats.Attack)"
                                     T="@byte"
                                     title="Attack GV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@Pokemon.GetMaxGanbaru(1)"
                                     @bind-Value="@gPkm.GV_ATK"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => gPkm.GV_ATK)"/>

                    <MudNumericField Label="Def"
                                     Class="@GetStatClass(Stats.Defense)"
                                     T="@byte"
                                     title="Defense GV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@Pokemon.GetMaxGanbaru(2)"
                                     @bind-Value="@gPkm.GV_DEF"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => gPkm.GV_DEF)"/>

                    <MudNumericField Label="Spa"
                                     Class="@GetStatClass(Stats.SpecialAttack)"
                                     T="@byte"
                                     title="Special Attack GV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@Pokemon.GetMaxGanbaru(3)"
                                     @bind-Value="@gPkm.GV_SPA"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => gPkm.GV_SPA)"/>

                    <MudNumericField Label="Spd"
                                     Class="@GetStatClass(Stats.SpecialDefense)"
                                     T="@byte"
                                     title="Special Defense GV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@Pokemon.GetMaxGanbaru(4)"
                                     @bind-Value="@gPkm.GV_SPD"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => gPkm.GV_SPD)"/>

                    <MudNumericField Label="Spe"
                                     Class="@GetStatClass(Stats.Speed)"
                                     T="@byte"
                                     title="Speed GV"
                                     Variant="@Variant.Outlined"
                                     Min="@byte.MinValue"
                                     Max="@Pokemon.GetMaxGanbaru(5)"
                                     @bind-Value="@gPkm.GV_SPE"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => gPkm.GV_SPE)"/>

                </MudStack>
            </MudItem>
        }
        else
        {
            <MudItem xs="3">
                <MudStack>
                    <MudStack Row
                              AlignItems="@AlignItems.Center"
                              Spacing="1">
                        <MudText>EVs</MudText>
                        <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.EVs)"
                                         Analysis="@Analysis"
                                         Title="EVs"/>
                    </MudStack>

                    <MudNumericField Label="HP"
                                     Class="@GetEvFieldClass(Pokemon.EV_HP, Stats.Hp, saveGeneration)"
                                     title="HP EV"
                                     Variant="@Variant.Outlined"
                                     Min="@int.MinValue"
                                     Max="@GetEvMax(saveGeneration)"
                                     @bind-Value="@Pokemon.EV_HP"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => Pokemon.EV_HP)"/>

                    <MudNumericField Label="Atk"
                                     Class="@GetEvFieldClass(Pokemon.EV_ATK, Stats.Attack, saveGeneration)"
                                     title="Attack EV"
                                     Variant="@Variant.Outlined"
                                     Min="@int.MinValue"
                                     Max="@GetEvMax(saveGeneration)"
                                     @bind-Value="@Pokemon.EV_ATK"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => Pokemon.EV_ATK)"/>

                    <MudNumericField Label="Def"
                                     Class="@GetEvFieldClass(Pokemon.EV_DEF, Stats.Defense, saveGeneration)"
                                     title="Defense EV"
                                     Variant="@Variant.Outlined"
                                     Min="@int.MinValue"
                                     Max="@GetEvMax(saveGeneration)"
                                     @bind-Value="@Pokemon.EV_DEF"
                                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                     For="@(() => Pokemon.EV_DEF)"/>

                    @if (saveGeneration == 1 && Pokemon is PK1 pk1)
                    {
                        <MudNumericField Label="Spe"
                                         Class="@GetEvFieldClass(pk1.EV_SPE, Stats.Speed, saveGeneration)"
                                         title="Speed EV"
                                         Variant="@Variant.Outlined"
                                         Min="@int.MinValue"
                                         Max="@GetEvMax(saveGeneration)"
                                         @bind-Value="@pk1.EV_SPE"
                                         @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                         For="@(() => pk1.EV_SPE)"/>

                        <MudNumericField Label="Spc"
                                         Class="@GetEvFieldClass(pk1.EV_SPC, Stats.Special, saveGeneration)"
                                         title="Special EV"
                                         Variant="@Variant.Outlined"
                                         Min="@int.MinValue"
                                         Max="@GetEvMax(saveGeneration)"
                                         @bind-Value="@pk1.EV_SPC"
                                         @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                         For="@(() => pk1.EV_SPC)"/>
                    }
                    else
                    {
                        <MudNumericField Label="Spa"
                                         Class="@GetEvFieldClass(Pokemon.EV_SPA, Stats.SpecialAttack, saveGeneration)"
                                         title="Special Attack EV"
                                         Variant="@Variant.Outlined"
                                         Min="@int.MinValue"
                                         Max="@GetEvMax(saveGeneration)"
                                         @bind-Value="@Pokemon.EV_SPA"
                                         @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                         For="@(() => Pokemon.EV_SPA)"/>

                        <MudNumericField Label="Spd"
                                         Class="@GetEvFieldClass(Pokemon.EV_SPD, Stats.SpecialDefense, saveGeneration)"
                                         title="Special Defense EV"
                                         Variant="@Variant.Outlined"
                                         Min="@int.MinValue"
                                         Max="@GetEvMax(saveGeneration)"
                                         @bind-Value="@Pokemon.EV_SPD"
                                         @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                         For="@(() => Pokemon.EV_SPD)"/>

                        <MudNumericField Label="Spe"
                                         Class="@GetEvFieldClass(Pokemon.EV_SPE, Stats.Speed, saveGeneration)"
                                         title="Speed EV"
                                         Variant="@Variant.Outlined"
                                         Min="@int.MinValue"
                                         Max="@GetEvMax(saveGeneration)"
                                         @bind-Value="@Pokemon.EV_SPE"
                                         @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                                         For="@(() => Pokemon.EV_SPE)"/>

                        <MudNumericField Label="Sum"
                                         title="EVs Total"
                                         Variant="@Variant.Outlined"
                                         Value="@Pokemon.EVTotal"
                                         ReadOnly
                                         HideSpinButtons/>
                    }

                </MudStack>
            </MudItem>
        }

        <MudItem xs="3">
            <MudStack>
                <MudStack Row
                          AlignItems="@AlignItems.Center"
                          Spacing="1">
                    <MudText>
                        Stats
                    </MudText>
                    @if (AppState?.IsHaXEnabled is true)
                    {
                        <MudChip T="string"
                                 Color="@Color.Warning"
                                 Size="@Size.Small"
                                 title="PKHaX: battle stats are directly editable">
                            HaX
                        </MudChip>
                    }
                </MudStack>

                <MudNumericField T="@int"
                                 Label="HP"
                                 title="Max HP Stat"
                                 Variant="@Variant.Outlined"
                                 Min="0"
                                 Max="@(ushort.MaxValue)"
                                 Value="@Pokemon.Stat_HPMax"
                                 ValueChanged="@(v => OnHaXStatHpSet(v))"
                                 ReadOnly="@(AppState?.IsHaXEnabled is not true)"
                                 HideSpinButtons="@(AppState?.IsHaXEnabled is not true)"/>

                <MudNumericField T="@int"
                                 Label="Atk"
                                 Class="@GetStatClass(Stats.Attack)"
                                 title="@GetNatureTooltip(Stats.Attack)"
                                 Variant="@Variant.Outlined"
                                 Min="0"
                                 Max="@(ushort.MaxValue)"
                                 Value="@Pokemon.Stat_ATK"
                                 ValueChanged="@(v => OnHaXStatSet(v, (s, val) => s.Stat_ATK = val))"
                                 Adornment="@GetNatureAdornment(Stats.Attack)"
                                 AdornmentIcon="@GetNatureAdornmentIcon(Stats.Attack)"
                                 AdornmentColor="@GetNatureAdornmentColor(Stats.Attack)"
                                 ReadOnly="@(AppState?.IsHaXEnabled is not true)"
                                 HideSpinButtons="@(AppState?.IsHaXEnabled is not true)"/>

                <MudNumericField T="@int"
                                 Label="Def"
                                 Class="@GetStatClass(Stats.Defense)"
                                 title="@GetNatureTooltip(Stats.Defense)"
                                 Variant="@Variant.Outlined"
                                 Min="0"
                                 Max="@(ushort.MaxValue)"
                                 Value="@Pokemon.Stat_DEF"
                                 ValueChanged="@(v => OnHaXStatSet(v, (s, val) => s.Stat_DEF = val))"
                                 Adornment="@GetNatureAdornment(Stats.Defense)"
                                 AdornmentIcon="@GetNatureAdornmentIcon(Stats.Defense)"
                                 AdornmentColor="@GetNatureAdornmentColor(Stats.Defense)"
                                 ReadOnly="@(AppState?.IsHaXEnabled is not true)"
                                 HideSpinButtons="@(AppState?.IsHaXEnabled is not true)"/>

                @if (saveGeneration == 1 && Pokemon is PK1 pk1)
                {
                    <MudNumericField T="@int"
                                     Label="Spe"
                                     title="Speed Stat"
                                     Variant="@Variant.Outlined"
                                     Min="0"
                                     Max="@(ushort.MaxValue)"
                                     Value="@pk1.Stat_SPE"
                                     ValueChanged="@(v => OnHaXStatSet(v, (s, val) => s.Stat_SPE = val))"
                                     ReadOnly="@(AppState?.IsHaXEnabled is not true)"
                                     HideSpinButtons="@(AppState?.IsHaXEnabled is not true)"/>

                    <MudNumericField T="@int"
                                     Label="Spc"
                                     title="Special Stat"
                                     Variant="@Variant.Outlined"
                                     Min="0"
                                     Max="@(ushort.MaxValue)"
                                     Value="@pk1.Stat_SPC"
                                     ValueChanged="@(v => OnHaXStatSet(v, (s, val) =>
                                                   {
                                                       if (s is PK1 p) p.Stat_SPC = val;
                                                   }))"
                                     ReadOnly="@(AppState?.IsHaXEnabled is not true)"
                                     HideSpinButtons="@(AppState?.IsHaXEnabled is not true)"/>
                }
                else
                {
                    <MudNumericField T="@int"
                                     Label="Spa"
                                     Class="@GetStatClass(Stats.SpecialAttack)"
                                     title="@GetNatureTooltip(Stats.SpecialAttack)"
                                     Variant="@Variant.Outlined"
                                     Min="0"
                                     Max="@(ushort.MaxValue)"
                                     Value="@Pokemon.Stat_SPA"
                                     ValueChanged="@(v => OnHaXStatSet(v, (s, val) => s.Stat_SPA = val))"
                                     Adornment="@GetNatureAdornment(Stats.SpecialAttack)"
                                     AdornmentIcon="@GetNatureAdornmentIcon(Stats.SpecialAttack)"
                                     AdornmentColor="@GetNatureAdornmentColor(Stats.SpecialAttack)"
                                     ReadOnly="@(AppState?.IsHaXEnabled is not true)"
                                     HideSpinButtons="@(AppState?.IsHaXEnabled is not true)"/>

                    <MudNumericField T="@int"
                                     Label="Spd"
                                     Class="@GetStatClass(Stats.SpecialDefense)"
                                     title="@GetNatureTooltip(Stats.SpecialDefense)"
                                     Variant="@Variant.Outlined"
                                     Min="0"
                                     Max="@(ushort.MaxValue)"
                                     Value="@Pokemon.Stat_SPD"
                                     ValueChanged="@(v => OnHaXStatSet(v, (s, val) => s.Stat_SPD = val))"
                                     Adornment="@GetNatureAdornment(Stats.SpecialDefense)"
                                     AdornmentIcon="@GetNatureAdornmentIcon(Stats.SpecialDefense)"
                                     AdornmentColor="@GetNatureAdornmentColor(Stats.SpecialDefense)"
                                     ReadOnly="@(AppState?.IsHaXEnabled is not true)"
                                     HideSpinButtons="@(AppState?.IsHaXEnabled is not true)"/>

                    <MudNumericField T="@int"
                                     Label="Spe"
                                     Class="@GetStatClass(Stats.Speed)"
                                     title="@GetNatureTooltip(Stats.Speed)"
                                     Variant="@Variant.Outlined"
                                     Min="0"
                                     Max="@(ushort.MaxValue)"
                                     Value="@Pokemon.Stat_SPE"
                                     ValueChanged="@(v => OnHaXStatSet(v, (s, val) => s.Stat_SPE = val))"
                                     Adornment="@GetNatureAdornment(Stats.Speed)"
                                     AdornmentIcon="@GetNatureAdornmentIcon(Stats.Speed)"
                                     AdornmentColor="@GetNatureAdornmentColor(Stats.Speed)"
                                     ReadOnly="@(AppState?.IsHaXEnabled is not true)"
                                     HideSpinButtons="@(AppState?.IsHaXEnabled is not true)"/>
                }

                @if (saveGeneration >= 3)
                {
                    <MudText>
                        <MudText>
                            @Pokemon.GetPotentialString()
                        </MudText>
                    </MudText>
                }

            </MudStack>
        </MudItem>

    </MudGrid>

    @if (IsPartyPokemon)
    {
        <MudPaper Class="pa-4 mt-2"
                  Elevation="1">
            <MudText Typo="Typo.h6">Party Stats</MudText>

            <MudGrid Class="mt-2">
                <MudItem xs="6">
                    <MudStack Row
                              AlignItems="@AlignItems.Center"
                              Spacing="2">
                        <MudNumericField T="@int"
                                         Label="Current HP"
                                         title="Current HP"
                                         Variant="@Variant.Outlined"
                                         Min="0"
                                         Max="@Pokemon.Stat_HPMax"
                                         Value="@Pokemon.Stat_HPCurrent"
                                         ValueChanged="@OnCurrentHpChanged"/>
                        <MudText Typo="Typo.body1"
                                 Class="mt-4">
                            / @Pokemon.Stat_HPMax
                        </MudText>
                        @if (Pokemon.Stat_HPCurrent == 0)
                        {
                            <MudImage Src="@ImageHelper.GetFaintStatusSpriteFileName()"
                                      Alt="Fainted"
                                      Width="24"
                                      Height="24"
                                      Class="mt-4"
                                      title="Fainted"/>
                        }
                    </MudStack>
                </MudItem>

                <MudItem xs="6">
                    <MudStack Row
                              AlignItems="@AlignItems.Center"
                              Spacing="2">
                        @{
                            var statusSprite = GetCurrentStatusSpriteFileName();
                        }
                        @if (statusSprite is not null && Pokemon.Stat_HPCurrent > 0)
                        {
                            <MudImage Src="@statusSprite"
                                      Alt="Status"
                                      Width="24"
                                      Height="24"
                                      Class="mt-4"/>
                        }
                        @{
                            var statusOptions = GetStatusOptions();
                            var currentStatusValue = GetCurrentStatusValue();
                        }
                        <AutocompleteSelect T="@int"
                                            Label="Status Condition"
                                            Value="@currentStatusValue"
                                            ValueChanged="@OnStatusChanged"
                                            Items="@statusOptions.Select(o => o.Value)"
                                            ToStringFunc="@(v => statusOptions.FirstOrDefault(o => o.Value == v)?.Label ?? string.Empty)">
                            <ItemTemplate Context="optionValue">
                                @{
                                    var option = statusOptions.FirstOrDefault(o => o.Value == optionValue);
                                }
                                @if (option is not null)
                                {
                                    <MudStack Row
                                              AlignItems="@AlignItems.Center"
                                              Spacing="1">
                                        @if (option.SpriteFileName is not null)
                                        {
                                            <MudImage Src="@option.SpriteFileName"
                                                      Alt="@option.Label"
                                                      Width="16"
                                                      Height="16"/>
                                        }
                                        <MudText>@option.Label</MudText>
                                    </MudStack>
                                }
                            </ItemTemplate>
                        </AutocompleteSelect>
                    </MudStack>

                    @if (Pokemon.Format <= 4 && IsSleepSelected())
                    {
                        <MudNumericField T="@int"
                                         Label="Sleep Turns"
                                         title="Sleep turn count (1-7)"
                                         Variant="@Variant.Outlined"
                                         Min="1"
                                         Max="7"
                                         Class="mt-2"
                                         Value="@GetSleepTurns()"
                                         ValueChanged="@OnSleepTurnsChanged"/>
                    }
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudNumericField Label="Level"
                     Variant="@Variant.Outlined"
                     @bind-Value="@Pokemon.CurrentLevel"
                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                     For="@(() => Pokemon.CurrentLevel)"/>

    @if (Pokemon is ICombatPower pb)
    {
        <MudNumericField Label="CP"
                         Variant="@Variant.Outlined"
                         ReadOnly
                         HideSpinButtons
                         Value="@pb.Stat_CP"
                         For="@(() => pb.Stat_CP)"/>
    }

    @if (saveGeneration >= 3)
    {
        <AutocompleteSelect T="@Nature"
                            Label="Nature"
                            @bind-Value:get="@Pokemon.Nature"
                            @bind-Value:set="@OnNatureSet"
                            Items="@GetNatureItems()"
                            ToStringFunc="@GetNatureName"
                            For="@(() => Pokemon.Nature)">
            <ItemTemplate Context="nature">
                <MudStack Row>
                    <MudText>
                        @GetNatureName(nature)
                    </MudText>
                    <MudText>
                        @AppService.GetStatModifierString(nature)
                    </MudText>
                </MudStack>
            </ItemTemplate>
        </AutocompleteSelect>
    }

    @if (saveGeneration >= 8)
    {
        <AutocompleteSelect T="@Nature"
                            Label="Stat Alignment"
                            @bind-Value:get="@Pokemon.StatAlignment"
                            @bind-Value:set="@OnStatAlignmentSet"
                            Items="@GetNatureItems()"
                            ToStringFunc="@GetNatureName"
                            For="@(() => Pokemon.StatAlignment)">
            <ItemTemplate Context="nature">
                <MudStack Row>
                    <MudText>
                        @GetNatureName(nature)
                    </MudText>
                    <MudText>
                        @AppService.GetStatModifierString(nature)
                    </MudText>
                </MudStack>
            </ItemTemplate>
        </AutocompleteSelect>
    }

    @if (GameInfo.FilteredSources.Moves.Any(m => m.Value == (int)Move.HiddenPower) && Pokemon is not { Context: EntityContext.Gen8 or EntityContext.Gen9 })
    {
        <HiddenPowerChooser Pokemon="@Pokemon"/>
    }

    @if (saveGeneration >= 4)
    {
        <MudText>
            Characteristic: @GetCharacteristic(Pokemon)
        </MudText>
    }
}

