@inherits BasePkmdsComponent
@inject ILegalityFixService LegalityFixService

@if (Pokemon is not null &&
     AppState is
     {
         SaveFile.Context: var saveFileEntityContext and not
         (EntityContext.None or
         EntityContext.SplitInvalid or
         EntityContext.MaxInvalid),
         SelectedSlotsAreValid: true
     })
{
    <MudStack Spacing="1">

        <MudStack Spacing="1">

            @for (var counter = 0; counter < Pokemon.Moves.Length; counter++)
            {
                var i = counter;
                var displayNumber = i + 1;
                var moveId = Pokemon.Moves[i];
                var showPlusMove = saveFileEntityContext.GetSingleGameVersion() == GameVersion.ZA;
                var showMasteredMove = saveFileEntityContext.GetSingleGameVersion() == GameVersion.PLA;

                var moveResult = Analysis?.Info.Moves[i];
                var hasMoveIssue = moveResult is { Valid: false };
                var moveMsgText = hasMoveIssue && moveResult is { } mr0
                    ? FormatMoveMessage(mr0, i)
                    : string.Empty;

                <MudGrid Spacing="1">
                    @* Move name — full width with type icon and checkboxes inline *@
                    <MudItem xs="12"
                             Class="@ColumnClass">
                        <MudStack Row
                                  AlignItems="@AlignItems.Center"
                                  Spacing="1"
                                  Style="width: 100%;">
                            @if (moveId != 0)
                            {
                                @MoveTypeAndCategorySummary(
                                    MoveInfo.GetType(moveId, saveFileEntityContext),
                                    GetMoveCategory(moveId, saveFileEntityContext))
                            }
                            else
                            {
                                <span style="width: 60px"></span>
                            }
                            <MudStack Style="flex: 1; min-width: 0;">
                                <AutocompleteSelect T="@ComboItem"
                                                    Label="@($"Move {displayNumber}")"
                                                    Margin="@Margin.Dense"
                                                    @bind-Value:get="@(AppService.GetMoveComboItem(moveId))"
                                                    @bind-Value:set="@(newMove => SetPokemonMove(i, newMove))"
                                                    Items="@AppService.GetMoves()"
                                                    ToStringFunc="@(move => move?.Text)">
                                    <ItemTemplate Context="move">
                                        @MoveRenderFragment(move, saveFileEntityContext)
                                    </ItemTemplate>
                                </AutocompleteSelect>
                            </MudStack>
                            <div
                                style="width: 20px; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                                @if (hasMoveIssue && moveResult is { } mr)
                                {
                                    <LegalityPopover SeverityOverride="@mr.Judgement"
                                                     MessageOverride="@moveMsgText"
                                                     Title="@($"Move {displayNumber}")"
                                                     QuickFixLabel="Suggest Moves"
                                                     OnQuickFix="@SuggestMoves"/>
                                }
                            </div>
                            @if (moveId != 0)
                            {
                                <InfoButton Title="@(moveInfos[i]?.Name ?? SafeNameLookup.Move(moveId))">
                                    <MudStack Spacing="2">
                                        @MoveTypeAndCategorySummary(
                                            MoveInfo.GetType(moveId, saveFileEntityContext),
                                            GetMoveCategory(moveId, saveFileEntityContext))
                                        @if (moveInfos[i] is { } moveInfo)
                                        {
                                            <MudStack Row
                                                      Spacing="3">
                                                <MudText Typo="@Typo.caption">Power:
                                                    <b>@(moveInfo.Power?.ToString() ?? "—")</b></MudText>
                                                @if (moveInfo.Pp.HasValue)
                                                {
                                                    <MudText Typo="@Typo.caption">PP: <b>@moveInfo.Pp</b></MudText>
                                                }
                                                <MudText Typo="@Typo.caption">Acc: <b>@(moveInfo.Accuracy is { } acc
                                                            ? $"{acc}%"
                                                            : "—")</b></MudText>
                                            </MudStack>
                                            @if (!string.IsNullOrEmpty(moveInfo.Target))
                                            {
                                                <MudText Typo="@Typo.caption">Target: <b>@moveInfo.Target</b></MudText>
                                            }

                                            @if (moveInfo.Priority != 0)
                                            {
                                                <MudText Typo="@Typo.caption">Priority:
                                                    <b>@FormatPriority(moveInfo.Priority)</b></MudText>
                                            }

                                            @if (moveInfo.SecondaryEffects is { } fx)
                                            {
                                                <MudStack Spacing="0">
                                                    @if (fx.Drain < 0)
                                                    {
                                                        <MudText Typo="@Typo.caption">Recoil: <b>@(Math.Abs(fx.Drain))%
                                                                of damage dealt</b></MudText>
                                                    }
                                                    else if (fx.Drain > 0)
                                                    {
                                                        <MudText Typo="@Typo.caption">Drains <b>@(fx.Drain)% of damage
                                                                dealt</b></MudText>
                                                    }
                                                    @if (fx.Healing > 0)
                                                    {
                                                        <MudText Typo="@Typo.caption">Restores <b>@(fx.Healing)% of max
                                                                HP</b></MudText>
                                                    }
                                                    @if (fx.AilmentId != 0 || fx.AilmentChance > 0)
                                                    {
                                                        var ailment = fx.AilmentId == -1
                                                            ? "a random status condition"
                                                            : (fx.AilmentName ?? "a status condition").ToLowerInvariant();
                                                        @if (fx.AilmentChance > 0)
                                                        {
                                                            <MudText Typo="@Typo.caption"><b>@(fx.AilmentChance)%</b>
                                                                chance to inflict <b>@ailment</b></MudText>
                                                        }
                                                        else
                                                        {
                                                            <MudText Typo="@Typo.caption">Inflicts <b>@ailment</b>
                                                            </MudText>
                                                        }
                                                    }
                                                    @if (fx.FlinchChance > 0)
                                                    {
                                                        <MudText Typo="@Typo.caption"><b>@(fx.FlinchChance)%</b> chance
                                                            to flinch
                                                        </MudText>
                                                    }
                                                    @if (fx.MinHits.HasValue || fx.MaxHits.HasValue)
                                                    {
                                                        var hitsText = (fx.MinHits, fx.MaxHits) switch
                                                        {
                                                            ({ } mn, { } mx) when mn == mx => $"Hits {mn} times",
                                                            ({ } mn, { } mx) => $"Hits {mn}–{mx} times",
                                                            ({ } mn, null) => $"Hits at least {mn} times",
                                                            (null, { } mx) => $"Hits up to {mx} times",
                                                            _ => string.Empty
                                                        };
                                                        @if (hitsText.Length > 0)
                                                        {
                                                            <MudText Typo="@Typo.caption"><b>@hitsText</b></MudText>
                                                        }
                                                    }
                                                    @if (fx.CritRate >= 6)
                                                    {
                                                        <MudText Typo="@Typo.caption"><b>Always lands a critical hit</b>
                                                        </MudText>
                                                    }
                                                    else if (fx.CritRate > 0)
                                                    {
                                                        <MudText Typo="@Typo.caption"><b>High critical hit ratio</b>
                                                        </MudText>
                                                    }
                                                    @{ var partialStatChance = fx.StatChance > 0 && fx.StatChance < 100; }
                                                    @foreach (var sc in fx.StatChanges)
                                                    {
                                                        var verbFull = sc.Change > 0
                                                            ? "Raises"
                                                            : "Lowers";
                                                        var verbBase = sc.Change > 0
                                                            ? "raise"
                                                            : "lower";
                                                        var stages = Math.Abs(sc.Change);
                                                        var stageWord = stages == 1
                                                            ? "stage"
                                                            : "stages";
                                                        @if (partialStatChance)
                                                        {
                                                            <MudText Typo="@Typo.caption"><b>@(fx.StatChance)%</b>
                                                                chance to @verbBase <b>@sc.Stat</b> by
                                                                <b>@stages @stageWord</b></MudText>
                                                        }
                                                        else
                                                        {
                                                            <MudText Typo="@Typo.caption">@verbFull <b>@sc.Stat</b> by
                                                                <b>@stages @stageWord</b></MudText>
                                                        }
                                                    }
                                                </MudStack>
                                            }

                                            @if (moveInfo.Flags.Count > 0)
                                            {
                                                <MudStack Row
                                                          Wrap="@Wrap.Wrap"
                                                          Spacing="1">
                                                    @foreach (var flag in moveInfo.Flags)
                                                    {
                                                        @if (FlagLabels.TryGetValue(flag, out var label) && IsFlagRelevant(flag, AppState.SaveFile?.Generation ?? int.MaxValue))
                                                        {
                                                            <MudChip T="string"
                                                                     Size="@Size.Small"
                                                                     Variant="@Variant.Outlined"
                                                                     Color="@Color.Default">@label</MudChip>
                                                        }
                                                    }
                                                </MudStack>
                                            }

                                            <MudText Typo="@Typo.body2">@(string.IsNullOrEmpty(moveInfo.Description)
                                                    ? "No description available."
                                                    : moveInfo.Description)</MudText>
                                        }
                                    </MudStack>
                                </InfoButton>
                            }
                            @if (showPlusMove)
                            {
                                var localMoveId = Pokemon.GetMove(i);
                                var plusFlagIndex = PersonalInfo9ZA.PlusMoves.IndexOf(localMoveId);
                                <HapticCheckBox T="@bool"
                                                Label="+"
                                                Dense
                                                title="Plus Move"
                                                @bind-Value:get="@GetPokemonMoveIsPlus(plusFlagIndex)"
                                                @bind-Value:set="@(newValue => SetPokemonMoveIsPlus(plusFlagIndex, newValue))"/>
                            }
                            @if (showMasteredMove && Pokemon is IMoveShop8Mastery)
                            {
                                var localMoveId = Pokemon.GetMove(i);
                                var masteredFlagIndex = GetMasteredRecordIndex(localMoveId);
                                <HapticCheckBox T="@bool"
                                                Label="+"
                                                Dense
                                                title="Mastered Move"
                                                Disabled="@(masteredFlagIndex < 0)"
                                                @bind-Value:get="@GetPokemonMoveIsMastered(masteredFlagIndex)"
                                                @bind-Value:set="@(newValue => SetPokemonMoveIsMastered(masteredFlagIndex, newValue))"/>
                            }
                        </MudStack>
                    </MudItem>

                    @* PP / Ups / Max on their own row *@
                    <MudItem xs="4"
                             Class="@ColumnClass">
                        <MudNumericField Label="PP"
                                         T="@int"
                                         Variant="@Variant.Outlined"
                                         Min="0"
                                         Margin="@Margin.Dense"
                                         @bind-Value:get="@GetPokemonPP(i)"
                                         @bind-Value:set="@(newValue => SetPokemonPP(i, newValue))"/>
                    </MudItem>

                    <MudItem xs="4"
                             Class="@ColumnClass">
                        <MudNumericField Label="Ups"
                                         T="@int"
                                         Variant="@Variant.Outlined"
                                         Max="3"
                                         Min="0"
                                         Margin="@Margin.Dense"
                                         @bind-Value:get="@GetPokemonPPUps(i)"
                                         @bind-Value:set="@(newValue => SetPokemonPPUps(i, newValue))"/>
                    </MudItem>

                    <MudItem xs="4"
                             Class="@ColumnClass">
                        <MudNumericField Label="Max"
                                         T="@int"
                                         Variant="@Variant.Outlined"
                                         Value="@Pokemon.GetMaxPP(i)"
                                         ReadOnly
                                         Margin="@Margin.Dense"
                                         HideSpinButtons/>
                    </MudItem>
                </MudGrid>
            }
        </MudStack>

        @{
            var hasNature = saveFileEntityContext is not (EntityContext.Gen1 or EntityContext.Gen2);
            // Abilities absent in Gen 1–2 and in side games that omit the ability system
            var hasAbility = saveFileEntityContext is not (
                EntityContext.Gen1 or EntityContext.Gen2 or
                EntityContext.Gen7b or EntityContext.Gen8a or EntityContext.Gen9a);
            var isGen1 = saveFileEntityContext is EntityContext.Gen1;
            var statNature = Pokemon.Format >= 8
                ? Pokemon.StatAlignment
                : Pokemon.Nature;
            var atkModifier = hasNature
                ? GetNatureModifier(statNature, Stats.Attack)
                : NatureModifier.Neutral;
            var spaModifier = hasNature
                ? GetNatureModifier(statNature, Stats.SpecialAttack)
                : NatureModifier.Neutral;
        }

        <MudPaper Outlined
                  Class="pa-2">
            <MudStack Row
                      Wrap="@Wrap.Wrap"
                      AlignItems="@AlignItems.Center"
                      Spacing="4">
                @if (hasAbility)
                {
                    <MudStack Row
                              AlignItems="@AlignItems.Center"
                              Spacing="1">
                        <MudText Typo="@Typo.caption"
                                 Color="@Color.Secondary">Ability
                        </MudText>
                        <MudText Typo="@Typo.body2">
                            <b>@SafeNameLookup.Ability(Pokemon.Ability)</b>
                        </MudText>
                        <InfoButton Title="@(abilityInfo?.Name ?? SafeNameLookup.Ability(Pokemon.Ability))">
                            <MudText Typo="@Typo.body2">@(abilityInfo is { Description: { Length: > 0 } desc }
                                    ? desc
                                    : "No description available.")</MudText>
                        </InfoButton>
                    </MudStack>
                }
                @if (hasNature)
                {
                    <MudStack Row
                              AlignItems="@AlignItems.Center"
                              Spacing="1">
                        <MudText Typo="@Typo.caption"
                                 Color="@Color.Secondary">Nature
                        </MudText>
                        <MudText Typo="@Typo.body2">
                            <b>@SafeNameLookup.Nature((int)statNature)</b>
                        </MudText>
                        <MudText Typo="@Typo.caption">@AppService.GetStatModifierString(statNature)</MudText>
                    </MudStack>
                }
                <MudStack Row
                          AlignItems="@AlignItems.Center"
                          Spacing="1">
                    <MudText Typo="@Typo.caption"
                             Color="@Color.Secondary">Atk
                    </MudText>
                    <MudText Typo="@Typo.body2"
                             Color="@GetNatureAdornmentColor(atkModifier)">
                        <b>@Pokemon.Stat_ATK</b>
                    </MudText>
                    @if (atkModifier is not NatureModifier.Neutral)
                    {
                        <MudIcon Icon="@GetNatureAdornmentIcon(atkModifier)"
                                 Size="@Size.Small"
                                 Color="@GetNatureAdornmentColor(atkModifier)"/>
                    }
                </MudStack>
                <MudStack Row
                          AlignItems="@AlignItems.Center"
                          Spacing="1">
                    <MudText Typo="@Typo.caption"
                             Color="@Color.Secondary">@(isGen1
                            ? "Special"
                            : "Sp. Atk")</MudText>
                    <MudText Typo="@Typo.body2"
                             Color="@GetNatureAdornmentColor(spaModifier)">
                        <b>@Pokemon.Stat_SPA</b>
                    </MudText>
                    @if (spaModifier is not NatureModifier.Neutral)
                    {
                        <MudIcon Icon="@GetNatureAdornmentIcon(spaModifier)"
                                 Size="@Size.Small"
                                 Color="@GetNatureAdornmentColor(spaModifier)"/>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (Pokemon.HasRelearnMoves())
        {
            <MudStack Spacing="1">
                <MudText Typo="@Typo.h6">Relearn Moves</MudText>

                @for (var counter = 0; counter < 4; counter++)
                {
                    var i = counter;
                    var displayNumber = i + 1;
                    var relearnMoveId = Pokemon.GetRelearnMove(i);
                    var relearnResult = Analysis?.Info.Relearn[i];
                    var hasRelearnIssue = relearnResult is { Valid: false };
                    var relearnMsgText = hasRelearnIssue && relearnResult is { } rr0
                        ? FormatMoveMessage(rr0, i)
                        : string.Empty;

                    <MudGrid Spacing="1">
                        <MudItem xs="1"
                                 Class="@ColumnClass">
                            @if (relearnMoveId != 0)
                            {
                                @MoveTypeAndCategorySummary(
                                    MoveInfo.GetType(relearnMoveId, saveFileEntityContext),
                                    GetMoveCategory(relearnMoveId, saveFileEntityContext))
                            }
                            else
                            {
                                <span style="width: 60px"></span>
                            }
                        </MudItem>

                        <MudItem xs="11"
                                 Class="@ColumnClass">
                            <MudStack Row
                                      AlignItems="@AlignItems.Center"
                                      Spacing="1">
                                <MudStack Style="flex: 1; min-width: 0;">
                                    <AutocompleteSelect T="@ComboItem"
                                                        Label="@($"Relearn {displayNumber}")"
                                                        Margin="@Margin.Dense"
                                                        @bind-Value:get="@(AppService.GetMoveComboItem(relearnMoveId))"
                                                        @bind-Value:set="@(newMove => SetPokemonRelearnMove(i, newMove))"
                                                        Items="@AppService.GetMoves()"
                                                        ToStringFunc="@(move => move?.Text)">
                                        <ItemTemplate Context="move">
                                            @MoveRenderFragment(move, saveFileEntityContext)
                                        </ItemTemplate>
                                    </AutocompleteSelect>
                                </MudStack>
                                <div
                                    style="width: 20px; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                                    @if (hasRelearnIssue && relearnResult is { } rr)
                                    {
                                        <LegalityPopover SeverityOverride="@rr.Judgement"
                                                         MessageOverride="@relearnMsgText"
                                                         Title="@($"Relearn {displayNumber}")"
                                                         QuickFixLabel="Suggest Relearn Moves"
                                                         OnQuickFix="@SuggestRelearnMoves"/>
                                    }
                                </div>
                                @if (relearnMoveId != 0)
                                {
                                    <InfoButton Title="@(relearnMoveInfos[i]?.Name ?? SafeNameLookup.Move(relearnMoveId))">
                                        <MudStack Spacing="2">
                                            @MoveTypeAndCategorySummary(
                                                MoveInfo.GetType(relearnMoveId, saveFileEntityContext),
                                                GetMoveCategory(relearnMoveId, saveFileEntityContext))
                                            @if (relearnMoveInfos[i] is { } relearnInfo)
                                            {
                                                <MudStack Row
                                                          Spacing="3">
                                                    <MudText Typo="@Typo.caption">Power:
                                                        <b>@(relearnInfo.Power?.ToString() ?? "—")</b></MudText>
                                                    @if (relearnInfo.Pp.HasValue)
                                                    {
                                                        <MudText Typo="@Typo.caption">PP: <b>@relearnInfo.Pp</b>
                                                        </MudText>
                                                    }
                                                    <MudText Typo="@Typo.caption">Acc:
                                                        <b>@(relearnInfo.Accuracy is { } relearnAcc
                                                                ? $"{relearnAcc}%"
                                                                : "—")</b></MudText>
                                                </MudStack>
                                                @if (!string.IsNullOrEmpty(relearnInfo.Target))
                                                {
                                                    <MudText Typo="@Typo.caption">Target: <b>@relearnInfo.Target</b>
                                                    </MudText>
                                                }

                                                @if (relearnInfo.Priority != 0)
                                                {
                                                    <MudText Typo="@Typo.caption">Priority:
                                                        <b>@(relearnInfo.Priority > 0
                                                                ? $"+{relearnInfo.Priority}"
                                                                : relearnInfo.Priority.ToString())</b></MudText>
                                                }

                                                @if (relearnInfo.Flags.Count > 0)
                                                {
                                                    <MudStack Row
                                                              Wrap="@Wrap.Wrap"
                                                              Spacing="1">
                                                        @foreach (var flag in relearnInfo.Flags)
                                                        {
                                                            @if (FlagLabels.TryGetValue(flag, out var label) && IsFlagRelevant(flag, AppState.SaveFile?.Generation ?? int.MaxValue))
                                                            {
                                                                <MudChip T="string"
                                                                         Size="@Size.Small"
                                                                         Variant="@Variant.Outlined"
                                                                         Color="@Color.Default">@label</MudChip>
                                                            }
                                                        }
                                                    </MudStack>
                                                }

                                                @if (!string.IsNullOrEmpty(relearnInfo.Description))
                                                {
                                                    <MudText Typo="@Typo.body2">@relearnInfo.Description</MudText>
                                                }
                                            }
                                        </MudStack>
                                    </InfoButton>
                                }
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                }

                @if (Pokemon is PA8 pa8)
                {
                    var alphaMoveId = pa8.AlphaMove;
                    <MudGrid Spacing="1">
                        <MudItem xs="1"
                                 Class="@ColumnClass">
                            @if (alphaMoveId != 0)
                            {
                                @MoveTypeAndCategorySummary(
                                    MoveInfo.GetType(alphaMoveId, saveFileEntityContext),
                                    GetMoveCategory(alphaMoveId, saveFileEntityContext))
                            }
                            else
                            {
                                <span style="width: 60px"></span>
                            }
                        </MudItem>

                        <MudItem xs="11"
                                 Class="@ColumnClass">
                            <MudStack Row
                                      AlignItems="@AlignItems.Center"
                                      Spacing="1"
                                      Style="width: 100%;">
                                <MudStack Style="flex: 1; min-width: 0;">
                                    <AutocompleteSelect T="@ComboItem"
                                                        Label="Alpha Move"
                                                        Margin="@Margin.Dense"
                                                        @bind-Value:get="@(AppService.GetMoveComboItem(alphaMoveId))"
                                                        @bind-Value:set="@(newMove => SetAlphaMove(newMove))"
                                                        Items="@AppService.GetMoves()"
                                                        ToStringFunc="@(move => move?.Text)">
                                        <ItemTemplate Context="move">
                                            @MoveRenderFragment(move, saveFileEntityContext)
                                        </ItemTemplate>
                                    </AutocompleteSelect>
                                </MudStack>
                                @if (alphaMoveId != 0)
                                {
                                    <InfoButton Title="@(alphaMoveInfo?.Name ?? SafeNameLookup.Move(alphaMoveId))">
                                        <MudStack Spacing="2">
                                            @MoveTypeAndCategorySummary(
                                                MoveInfo.GetType(alphaMoveId, saveFileEntityContext),
                                                GetMoveCategory(alphaMoveId, saveFileEntityContext))
                                            @if (alphaMoveInfo is { } alphaInfo)
                                            {
                                                <MudStack Row
                                                          Spacing="3">
                                                    <MudText Typo="@Typo.caption">Power:
                                                        <b>@(alphaInfo.Power?.ToString() ?? "—")</b></MudText>
                                                    @if (alphaInfo.Pp.HasValue)
                                                    {
                                                        <MudText Typo="@Typo.caption">PP: <b>@alphaInfo.Pp</b></MudText>
                                                    }
                                                    <MudText Typo="@Typo.caption">Acc:
                                                        <b>@(alphaInfo.Accuracy is { } alphaAcc
                                                                ? $"{alphaAcc}%"
                                                                : "—")</b></MudText>
                                                </MudStack>
                                                @if (!string.IsNullOrEmpty(alphaInfo.Target))
                                                {
                                                    <MudText Typo="@Typo.caption">Target: <b>@alphaInfo.Target</b>
                                                    </MudText>
                                                }

                                                @if (alphaInfo.Priority != 0)
                                                {
                                                    <MudText Typo="@Typo.caption">Priority: <b>@(alphaInfo.Priority > 0
                                                                ? $"+{alphaInfo.Priority}"
                                                                : alphaInfo.Priority.ToString())</b></MudText>
                                                }

                                                @if (alphaInfo.Flags.Count > 0)
                                                {
                                                    <MudStack Row
                                                              Wrap="@Wrap.Wrap"
                                                              Spacing="1">
                                                        @foreach (var flag in alphaInfo.Flags)
                                                        {
                                                            @if (FlagLabels.TryGetValue(flag, out var label) && IsFlagRelevant(flag, AppState.SaveFile?.Generation ?? int.MaxValue))
                                                            {
                                                                <MudChip T="string"
                                                                         Size="@Size.Small"
                                                                         Variant="@Variant.Outlined"
                                                                         Color="@Color.Default">@label</MudChip>
                                                            }
                                                        }
                                                    </MudStack>
                                                }

                                                @if (!string.IsNullOrEmpty(alphaInfo.Description))
                                                {
                                                    <MudText Typo="@Typo.body2">@alphaInfo.Description</MudText>
                                                }
                                            }
                                        </MudStack>
                                    </InfoButton>
                                }
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                }

                @if (Pokemon is ITechRecord)
                {
                    <MudButton Variant="@Variant.Outlined"
                               Color="@Color.Primary"
                               OnClick="@OpenRelearnFlagsDialog">
                        Relearn Flags
                    </MudButton>
                }

                @if (Pokemon is IMoveShop8)
                {
                    <MudButton Variant="@Variant.Outlined"
                               Color="@Color.Primary"
                               OnClick="@OpenMoveShopDialog">
                        Move Shop
                    </MudButton>
                }

                @if (Pokemon is PA9)
                {
                    <MudButton Variant="@Variant.Outlined"
                               Color="@Color.Primary"
                               OnClick="@OpenPlusFlagsDialog">
                        Plus Flags
                    </MudButton>
                }
            </MudStack>
        }

        @if (GameInfo.FilteredSources.Moves.Any(m => m.Value == (int)Move.HiddenPower) && Pokemon is not { Context: EntityContext.Gen8 or EntityContext.Gen9 })
        {
            <HiddenPowerChooser Pokemon="@Pokemon"/>
        }

    </MudStack>
}

@code {

    private RenderFragment MoveRenderFragment(ComboItem? move, EntityContext saveFileEntityContext)
    {
        if (move is null)
        {
            return @<span>(None)</span>;
        }

        return @<MudStack Row
                          AlignItems="@AlignItems.Center">
                   @if (move.Value != 0)
                   {
                       @MoveTypeAndCategorySummary(
                           MoveInfo.GetType((ushort)move.Value, saveFileEntityContext),
                           GetMoveCategory((ushort)move.Value, saveFileEntityContext))
                   }
                   <MudText>
                       @move.Text
                   </MudText>
               </MudStack>;
    }

}
