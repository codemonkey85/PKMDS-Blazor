@inherits BasePkmdsComponent

@if (Pokemon is not null &&
     AppState is
     {
         SaveFile:
         {
             Context: not
             (EntityContext.None or
             EntityContext.SplitInvalid or
             EntityContext.MaxInvalid),
             Generation: var saveGeneration
         } saveFile,
         SelectedSlotsAreValid: true
     })
{
    @if (saveGeneration >= 3)
    {
        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="1">
            <MudStack Style="flex: 1; min-width: 0;">
                <MudNumericField Label="PID"
                                 Variant="@Variant.Outlined"
                                 Min="0U"
                                 Max="@uint.MaxValue"
                                 @bind-Value:get="@Pokemon.PID"
                                 @bind-Value:set="@(newPid => SetPokemonPid(newPid))"
                                 For="@(() => Pokemon.PID)"/>
            </MudStack>
            <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.PID)"
                             Analysis="@Analysis"
                             Title="PID"/>
        </MudStack>

        <MudTextField Label="PID (Hex)"
                      Variant="@Variant.Outlined"
                      MaxLength="8"
                      Mask="@Constants.HexMask"
                      @bind-Value:get="@Pokemon.PID.ToString("X8")"
                      @bind-Value:set="@((string newPidHex) => SetPokemonPid(newPidHex))"/>

        <MudButton OnClick="@OpenPidEcDialog"
                   Variant="@Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.AutoFixHigh"
                   Class="mb-2">
            Generate PID / EC...
        </MudButton>

        @if (IsSpinda)
        {
            <MudButton OnClick="@OpenSpindaPatternDialog"
                       Variant="@Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Pets"
                       Class="mb-2">
                View Spot Pattern...
            </MudButton>
        }
    }

    @* ReSharper disable once CSharpWarnings::CS8603 *@
    <MudAutocomplete T="@ComboItem"
                     Label="Species"
                     Variant="@Variant.Outlined"
                     @bind-Value:get="@(AppService.GetSpeciesComboItem(Pokemon.Species))"
                     @bind-Value:set="@(species => SetSpecies((ushort)species.Value))"
                     SearchFunc="@SearchPokemonNames"
                     ToStringFunc="@(species => species?.Text)"/>

    if (Pokemon != saveFile.BlankPKM && Pokemon.Species.IsValidSpecies())
    {
        @TypeSummary(Pokemon.GetGenerationTypes())
    }

    @if (CanEvolve)
    {
        <MudButton OnClick="@EvolveAsync"
                   Variant="@Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Upgrade"
                   Color="@Color.Primary"
                   Class="mb-2">
            Evolve...
        </MudButton>
    }

    <MudStack Row>

        <HapticCheckBox T="@bool"
                        Label="Is Nicknamed"
                        @bind-Value="@Pokemon.IsNicknamed"
                        For="@(() => Pokemon.IsNicknamed)"/>

        <MudButton OnClick="@RevertNickname"
                   ButtonType="@ButtonType.Button"
                   Variant="@Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Undo"
                   Color="@Color.Default"
                   Disabled="@(!Pokemon.IsNicknamed)">
            Revert Nickname
        </MudButton>

    </MudStack>

    <MudStack Row
              AlignItems="@AlignItems.Center"
              Spacing="1">
        <MudStack Style="flex: 1; min-width: 0;">
            <MudTextField Label="Nickname"
                          Variant="@Variant.Outlined"
                          Text="@Pokemon.Nickname"
                          TextChanged="@SetPokemonNickname"
                          MaxLength="@saveFile.MaxStringLengthNickname"
                          For="@(() => Pokemon.Nickname)"/>
        </MudStack>
        <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.Nickname)"
                         Analysis="@Analysis"
                         Title="Nickname"/>
        @if (Pokemon.NicknameTrash.Length > 0)
        {
            <MudTooltip Text="Edit trash bytes...">
                <MudIconButton Icon="@Icons.Material.Filled.EditNote"
                               Size="@Size.Small"
                               OnClick="@(() => OpenTrashBytesEditor(StringSource.Nickname))"/>
            </MudTooltip>
        }
    </MudStack>

    @if (saveGeneration >= 2)
    {
        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="1">
            <GenderDisplayComponent Gender="@((Gender)Pokemon.Gender)"
                                    OnChange="@OnGenderToggle"
                                    ReadOnly="@(!Pokemon.PersonalInfo.IsDualGender)"/>
            <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.Gender)"
                             Analysis="@Analysis"
                             Title="Gender"/>
        </MudStack>
    }

    <MudNumericField Label="Level"
                     Variant="@Variant.Outlined"
                     @bind-Value="@Pokemon.CurrentLevel"
                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                     For="@(() => Pokemon.CurrentLevel)"/>

    <MudNumericField Label="EXP"
                     Variant="@Variant.Outlined"
                     @bind-Value="@Pokemon.EXP"
                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                     For="@(() => Pokemon.EXP)"/>

    <MudNumericField Label="EXP to next level"
                     Variant="@Variant.Outlined"
                     Value="@GetEXPToLevelUp()"
                     ReadOnly
                     HideSpinButtons/>

    var levelProgress = Experience.GetEXPToLevelUpPercentage(Pokemon.CurrentLevel, Pokemon.EXP, Pokemon.PersonalInfo.EXPGrowth);
    <MudProgressLinear
        Value="@(levelProgress * 100)"
        Color="@Color.Primary"
        Size="@Size.Medium"
        Rounded
        Class="mt-2"
        title="@(levelProgress.ToString("P0"))"/>

    @if (saveGeneration >= 3)
    {
        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="1">
            <MudStack Style="flex: 1; min-width: 0;">
                <AutocompleteSelect T="@Nature"
                                    Label="Nature"
                                    @bind-Value:get="@Pokemon.Nature"
                                    @bind-Value:set="@OnNatureSet"
                                    Items="@GetNatureItems()"
                                    ToStringFunc="@GetNatureName"
                                    For="@(() => Pokemon.Nature)">
                    <ItemTemplate Context="nature">
                        <MudStack Row>
                            <MudText>
                                @GetNatureName(nature)
                            </MudText>
                            <MudText>
                                @AppService.GetStatModifierString(nature)
                            </MudText>
                        </MudStack>
                    </ItemTemplate>
                </AutocompleteSelect>
            </MudStack>
            <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.Nature)"
                             Analysis="@Analysis"
                             Title="Nature"/>
        </MudStack>
    }

    @if (saveGeneration >= 8)
    {
        <AutocompleteSelect T="@Nature"
                            Label="Stat Alignment"
                            @bind-Value:get="@Pokemon.StatAlignment"
                            @bind-Value:set="@OnStatAlignmentSet"
                            Items="@GetNatureItems()"
                            ToStringFunc="@GetNatureName"
                            For="@(() => Pokemon.StatAlignment)">
            <ItemTemplate Context="nature">
                <MudStack Row>
                    <MudText>
                        @GetNatureName(nature)
                    </MudText>
                    <MudText>
                        @AppService.GetStatModifierString(nature)
                    </MudText>
                </MudStack>
            </ItemTemplate>
        </AutocompleteSelect>
    }

    @if (FormInfo.HasFormSelection(saveFile.Personal[Pokemon.Species], Pokemon.Species, Pokemon.Format))
    {
        var forms = FormConverter.GetFormList(Pokemon.Species, GameInfo.Strings.types, GameInfo.Strings.forms, GameInfo.GenderSymbolUnicode, Pokemon.Context);
        if (forms.AsEnumerable().Any(f => !string.IsNullOrEmpty(f)))
        {
            <MudStack Row
                      AlignItems="@AlignItems.Center"
                      Spacing="1">
                <MudStack Style="flex: 1; min-width: 0;">
                    <AutocompleteSelect T="@byte"
                                        Label="Form"
                                        @bind-Value="@Pokemon.Form"
                                        @bind-Value:after="@AfterFormChanged"
                                        Items="@Enumerable.Range(0, forms.Length).Select(i => (byte)i)"
                                        ToStringFunc="@(i => i < forms.Length ? forms[i] : string.Empty)"
                                        For="@(() => Pokemon.Form)"/>
                </MudStack>
                <MudImage Src="@GetFormPreviewSprite()"
                          Alt="Form preview"
                          title="@forms.ElementAtOrDefault(Pokemon.Form)"
                          ObjectFit="@ObjectFit.Contain"
                          ObjectPosition="@ObjectPosition.Center"
                          Width="40"
                          Height="30"/>
                <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.Form)"
                                 Analysis="@Analysis"
                                 Title="Form"/>
            </MudStack>

            @if (Pokemon is IFormArgument && FormArgumentUtil.GetFormArgumentMax(Pokemon.Species, Pokemon.Form, Pokemon.Context) > 0 && FormConverter.GetFormArgumentIsNamedIndex(Pokemon.Species))
            {
                var formArgs = FormConverter.GetFormArgumentStrings(Pokemon.Species);
                <AutocompleteSelect T="@(uint?)"
                                    Label="Form Arg"
                                    @bind-Value:get="@(Pokemon.GetFormArgument())"
                                    @bind-Value:set="@(formArg =>
                                            {
                                                Pokemon.ChangeFormArgument(formArg ?? 0);
                                                AppService.LoadPokemonStats(Pokemon);
                                                RefreshService.Refresh();
                                            })"
                                    Items="@Enumerable.Range(0, formArgs.Length).Select(i => (uint?)i)"
                                    ToStringFunc="@(i => i is { } v && v < formArgs.Length ? formArgs[v] : string.Empty)"/>
            }

            @if (IsAlcremie)
            {
                <MudButton OnClick="@OpenAlcremieEditorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Palette"
                           Class="mb-2">
                    Edit Appearance...
                </MudButton>
            }
            else if (IsVivillon)
            {
                <MudButton OnClick="@OpenVivillonEditorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Palette"
                           Class="mb-2">
                    Edit Pattern...
                </MudButton>
            }
            else if (IsFurfrou)
            {
                <MudButton OnClick="@OpenFurfrouEditorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.ContentCut"
                           Class="mb-2">
                    Edit Trim...
                </MudButton>
            }
            else if (IsPumpkabooOrGourgeist)
            {
                <MudButton OnClick="@OpenPumpkabooSizeDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Straighten"
                           Class="mb-2">
                    Edit Size...
                </MudButton>
            }
            else if (IsMinior)
            {
                <MudButton OnClick="@OpenMiniorColorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.ColorLens"
                           Class="mb-2">
                    Edit Color...
                </MudButton>
            }
            else if (IsFlabebebFamily)
            {
                <MudButton OnClick="@OpenFlowerColorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.LocalFlorist"
                           Class="mb-2">
                    Edit Flower Color...
                </MudButton>
            }
        }
    }

    @if (saveGeneration >= 2 && saveFile.HeldItems.Length > 0)
    {
        <MudStack Row
                  Spacing="1"
                  AlignItems="@AlignItems.Center">

            @* ReSharper disable once CSharpWarnings::CS8603 *@
            <MudAutocomplete T="@ComboItem"
                             Label="Held Item"
                             Variant="@Variant.Outlined"
                             Clearable
                             @bind-Value:get="@(AppService.GetItemComboItem(Pokemon.HeldItem))"
                             @bind-Value:set="@SetHeldItem"
                             SearchFunc="@SearchItemNames"
                             ToStringFunc="@(item => item?.Text)">
                <ItemTemplate Context="item">
                    <MudStack Row>
                        @if (item.Value != 0)
                        {
                            <MudImage Src="@ImageHelper.GetItemSpriteFilename(item.Value, Pokemon.Context)"
                                      Alt="@item.Text"
                                      title="@item.Text"
                                      ObjectFit="@ObjectFit.Contain"
                                      ObjectPosition="@ObjectPosition.Center"
                                      Width="22"
                                      Height="22"/>
                        }
                        <MudText>
                            @item.Text
                        </MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>

            @if (Pokemon.HeldItem != 0)
            {
                var itemText = AppService.GetItemComboItem(Pokemon.HeldItem).Text;
                <MudImage Src="@ImageHelper.GetItemSpriteFilename(Pokemon.HeldItem, Pokemon.Context)"
                          Alt="@itemText"
                          title="@itemText"
                          ObjectFit="@ObjectFit.Contain"
                          ObjectPosition="@ObjectPosition.Center"
                          Width="22"
                          Height="22"/>
                <InfoButton Title="@(heldItemInfo?.Name ?? itemText)">
                    @if (heldItemInfo is { } itemInfo)
                    {
                        <MudText Typo="@Typo.body2">
                            @(string.IsNullOrEmpty(itemInfo.Description)
                                ? "No description available."
                                : itemInfo.Description)
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="@Typo.body2">No description available.</MudText>
                    }
                </InfoButton>
            }
            <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.HeldItem)"
                             Analysis="@Analysis"
                             Title="Held Item"/>
        </MudStack>
    }

    @if (saveGeneration >= 3)
    {
        @if (AppState is { IsHaXEnabled: true } && Pokemon.Format > 3)
        {
            @* DEV_Ability: HaX mode — any ability ID.
               AbilityNumber is independently stored (Gen 6+), so the slot picker
               is only shown for Gen 6+. For Gen 4/5, AbilityNumber.set is a no-op
               in PKHeX.Core (derived from PID), so we omit the picker there. *@
            <MudStack Row
                      AlignItems="@AlignItems.Center"
                      Spacing="1">
                <MudStack Style="flex: 1; min-width: 0;">
                    <MudAutocomplete T="ComboItem"
                                     Label="Ability (HaX — any)"
                                     Variant="@Variant.Outlined"
                                     Value="@GetDevAbilityComboItem()"
                                     ValueChanged="@SetDevAbility"
                                     SearchFunc="@SearchAllAbilities"
                                     ToStringFunc="@(item => item?.Text)"
                                     ResetValueOnEmptyText
                                     CoerceValue/>
                </MudStack>
                @if (Pokemon.Format >= 6)
                {
                    @* Gen 6+: AbilityNumber is independently stored and freely writable *@
                    <AutocompleteSelect T="@int"
                                        Label="Slot"
                                        Style="max-width: 110px;"
                                        Value="@Pokemon.AbilityNumber"
                                        ValueChanged="@SetDevAbilityNumber"
                                        Items="@GetAbilityNumberItems().Select(s => s.Value)"
                                        ToStringFunc="@(v => GetAbilityNumberItems().FirstOrDefault(s => s.Value == v)?.Text ?? v.ToString())"/>
                }
                <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.Ability)"
                                 Analysis="@Analysis"
                                 Title="Ability"/>
                <InfoButton Title="@(abilityInfo?.Name ?? SafeNameLookup.Ability(Pokemon!.Ability))">
                    <MudText Typo="@Typo.body2">@(abilityInfo is { Description: { Length: > 0 } desc }
                            ? desc
                            : "No description available.")</MudText>
                </InfoButton>
            </MudStack>
        }
        else
        {
            <MudStack Row
                      AlignItems="@AlignItems.Center"
                      Spacing="1">
                <MudStack Style="flex: 1; min-width: 0;">
                    <AutocompleteSelect T="@int"
                                        Label="Ability"
                                        Value="@GetAbilitySlotIndex()"
                                        ValueChanged="@SetAbilitySlot"
                                        Items="@GetAbilitySlotItems().Select(s => s.Value)"
                                        ToStringFunc="@(v => GetAbilitySlotItems().FirstOrDefault(s => s.Value == v)?.Text ?? v.ToString())"/>
                </MudStack>
                <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.Ability)"
                                 Analysis="@Analysis"
                                 Title="Ability"/>
                <InfoButton Title="@(abilityInfo?.Name ?? SafeNameLookup.Ability(Pokemon!.Ability))">
                    <MudText Typo="@Typo.body2">@(abilityInfo is { Description: { Length: > 0 } desc }
                            ? desc
                            : "No description available.")</MudText>
                </InfoButton>
            </MudStack>
        }
    }

    @if (saveGeneration >= 3)
    {
        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="1">
            <MudStack Style="flex: 1; min-width: 0;">
                <AutocompleteSelect T="@int"
                                    Label="Language"
                                    @bind-Value="@Pokemon.Language"
                                    Items="@LanguageItems"
                                    ToStringFunc="@GetLanguageText"
                                    For="@(() => Pokemon.Language)"/>
            </MudStack>
            <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.Language)"
                             Analysis="@Analysis"
                             Title="Language"/>
        </MudStack>
    }

    @if (saveGeneration >= 2)
    {
        <MudNumericField Label="@(Pokemon.IsEgg
                                    ? "Hatch Counter"
                                    : "Friendship")"
                         Variant="@Variant.Outlined"
                         Min="@byte.MinValue"
                         Max="@byte.MaxValue"
                         @bind-Value="@Pokemon.CurrentFriendship"
                         For="@(() => Pokemon.CurrentFriendship)"/>
    }

    <MudStack Row
              Wrap="@Wrap.Wrap">

        @if (saveGeneration >= 2)
        {
            <MudStack Row
                      AlignItems="@AlignItems.Center"
                      Spacing="0">
                <HapticCheckBox T="@bool"
                                Label="Is Egg"
                                @bind-Value="@Pokemon.IsEgg"
                                @bind-Value:after="@RefreshService.Refresh"
                                For="@(() => Pokemon.IsEgg)"/>
                <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.Egg)"
                                 Analysis="@Analysis"
                                 Title="Egg"/>
            </MudStack>

            <PokerusComponent Pokemon="Pokemon"/>
        }

        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="0">
            <HapticCheckBox T="@bool"
                            Label="Shiny"
                            @bind-Value:get="@Pokemon.GetIsShinySafe()"
                            @bind-Value:set="@(isShiny => OnShinySet(isShiny))"
                            For="@(() => Pokemon.IsShiny)"/>
            <LegalityPopover Result="@LegalityHelpers.GetCheckResult(Analysis, CheckIdentifier.Shiny)"
                             Analysis="@Analysis"
                             Title="Shiny"/>
        </MudStack>

    </MudStack>
}
