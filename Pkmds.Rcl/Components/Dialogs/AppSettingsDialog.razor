@inherits MudComponentBase

<MudDialog>
    <TitleContent>
        <MudText Typo="@Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Settings"
                     Class="mr-2"
                     Style="vertical-align: middle;"/>
            Settings
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0"
                 Rounded="false"
                 ApplyEffectsToContainer>

            <!-- Tab 1: UI Preferences -->
            <MudTabPanel Text="UI">
                <MudStack Spacing="3"
                          Class="pa-4">
                    @* Theme picker hidden in embed mode — host owns appearance,
                       ThemeMode is force-locked to System in SettingsService. *@
                    @if (!HostService.IsEmbedded)
                    {
                        <MudText Typo="@Typo.subtitle1"
                                 Color="@Color.Primary">
                            Theme
                        </MudText>
                        <MudToggleGroup T="ThemeMode"
                                        @bind-Value="@themeMode"
                                        Color="@Color.Primary"
                                        Size="@Size.Small">
                            <MudToggleItem T="ThemeMode"
                                           Value="@ThemeMode.Light"
                                           title="Light mode">
                                <MudIcon Icon="@Icons.Material.Filled.LightMode"
                                         Size="@Size.Small"/>
                            </MudToggleItem>
                            <MudToggleItem T="ThemeMode"
                                           Value="@ThemeMode.System"
                                           title="System default">
                                <MudIcon Icon="@Icons.Material.Filled.SettingsBrightness"
                                         Size="@Size.Small"/>
                            </MudToggleItem>
                            <MudToggleItem T="ThemeMode"
                                           Value="@ThemeMode.Dark"
                                           title="Dark mode">
                                <MudIcon Icon="@Icons.Material.Filled.DarkMode"
                                         Size="@Size.Small"/>
                            </MudToggleItem>
                        </MudToggleGroup>

                        <MudDivider/>
                    }

                    @* Sprite Style hidden in embed mode — PokeAPI overlay is
                       suppressed for embedded sessions, so the choice has no
                       visible effect. *@
                    @if (!HostService.IsEmbedded)
                    {
                        <MudText Typo="@Typo.subtitle1"
                                 Color="@Color.Primary">
                            Sprite Style
                        </MudText>
                        <MudToggleGroup T="SpriteStyle"
                                        @bind-Value="@spriteStyle"
                                        Color="@Color.Primary"
                                        Size="@Size.Small">
                            <MudToggleItem T="SpriteStyle"
                                           Value="@SpriteStyle.Home"
                                           title="Home (high-res 512×512 sprites)">
                                <MudStack Row
                                          AlignItems="@AlignItems.Center"
                                          Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Home"
                                             Size="@Size.Small"/>
                                    <span>Home</span>
                                </MudStack>
                            </MudToggleItem>
                            <MudToggleItem T="SpriteStyle"
                                           Value="@SpriteStyle.Game"
                                           title="Game (era-accurate pixel-art sprites matched to save file)">
                                <MudStack Row
                                          AlignItems="@AlignItems.Center"
                                          Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.VideogameAsset"
                                             Size="@Size.Small"/>
                                    <span>Game</span>
                                </MudStack>
                            </MudToggleItem>
                        </MudToggleGroup>
                        <MudButton StartIcon="@Icons.Material.Filled.ImageNotSupported"
                                   Variant="@Variant.Filled"
                                   Size="@Size.Small"
                                   Color="@Color.Default"
                                   title="Forces all high-res sprites to reload from the CDN"
                                   OnClick="@(() => PokemonSlotComponent.ClearSpriteCache())">
                            Clear Sprite Cache
                        </MudButton>

                        <MudDivider/>
                    }

                    <MudText Typo="@Typo.subtitle1"
                             Color="@Color.Primary">
                        Legality Indicators
                    </MudText>
                    <MudText Typo="@Typo.caption"
                             Color="@Color.Secondary">
                        Choose which overlay icons appear on box and party slots.
                    </MudText>
                    <MudSwitch T="@bool"
                               Value="@showLegalIndicator"
                               Color="@Color.Success"
                               Label="Show Legal (green)"
                               title="Show a green check on slots whose Pokémon are fully legal"
                               ValueChanged="@(v => OnToggle(v, x => showLegalIndicator = x))"/>
                    <MudSwitch T="@bool"
                               Value="@showFishyIndicator"
                               Color="@Color.Warning"
                               Label="Show Fishy (yellow)"
                               title="Show a yellow warning on slots whose Pokémon pass legality but have suspicious checks"
                               ValueChanged="@(v => OnToggle(v, x => showFishyIndicator = x))"/>
                    <MudSwitch T="@bool"
                               Value="@showIllegalIndicator"
                               Color="@Color.Error"
                               Label="Show Illegal (red)"
                               title="Show a red indicator on slots whose Pokémon fail legality"
                               ValueChanged="@(v => OnToggle(v, x => showIllegalIndicator = x))"/>

                    <MudDivider/>

                    @* Haptics hidden in embed mode — iOS WebKit doesn't implement
                       navigator.vibrate, so the toggle has no effect in any
                       embedded WKWebView host. *@
                    @if (!HostService.IsEmbedded)
                    {
                        <MudText Typo="@Typo.subtitle1"
                                 Color="@Color.Primary">
                            Haptic Feedback
                        </MudText>
                        <MudSwitch T="@bool"
                                   Value="@hapticsEnabled"
                                   Color="@Color.Primary"
                                   Label="Enable haptics"
                                   title="Short vibration pulses on drag, drop, save export, and other key actions. No effect on iOS — Safari does not support web haptics."
                                   ValueChanged="@(v => OnToggle(v, x => hapticsEnabled = x))"/>

                        <MudDivider/>
                    }

                    <MudText Typo="@Typo.subtitle1"
                             Color="@Color.Primary">
                        Developer Options
                    </MudText>
                    <MudSwitch T="@bool"
                               Value="@isHaXEnabled"
                               Color="@Color.Warning"
                               Label="PKHaX Mode"
                               title="Enables unrestricted editing. May create illegal/untradable Pokémon. Use at your own risk."
                               ValueChanged="@(value => OnHaXEnabledChanged(value))"/>
                    <MudSwitch T="@bool"
                               Value="@isVerboseLogging"
                               Color="@Color.Primary"
                               Label="Verbose Logging"
                               title="Enable verbose logging to browser console"
                               ValueChanged="@(v => OnToggle(v, x => isVerboseLogging = x))"/>
                </MudStack>
            </MudTabPanel>

            <!-- Tab 2: Trainer Defaults -->
            <MudTabPanel Text="Trainer Defaults">
                <MudStack Spacing="3"
                          Class="pa-4">
                    <MudText Typo="@Typo.caption"
                             Color="@Color.Secondary">
                        Configure your preferred trainer default values.
                    </MudText>
                    <MudTextField @bind-Value="@defaultOtName"
                                  Label="Default OT Name"
                                  MaxLength="12"
                                  Variant="@Variant.Outlined"
                                  Clearable/>
                    <MudNumericField @bind-Value="@defaultTrainerId"
                                     Label="Default TID"
                                     Variant="@Variant.Outlined"
                                     Min="@((uint)0)"
                                     Max="@((uint)999999)"/>
                    <MudNumericField @bind-Value="@defaultSecretId"
                                     Label="Default SID"
                                     Variant="@Variant.Outlined"
                                     Min="@((uint)0)"
                                     Max="@((uint)65535)"/>
                    <MudSelect @bind-Value="@defaultLanguageId"
                               Label="Default Language"
                               Variant="@Variant.Outlined">
                        @foreach (var lang in SupportedLanguages)
                        {
                            <MudSelectItem Value="@lang.Id">@lang.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
            </MudTabPanel>

            @* Advanced tab is entirely standalone-only: Backup uses IndexedDB
               history that doesn't fit a one-shot edit session, and Clear App
               Cache would tear down the WKWebView session. *@
            @if (!HostService.IsEmbedded)
            {
                <!-- Tab 3: Advanced -->
                <MudTabPanel Text="Advanced">
                    <MudStack Spacing="3"
                              Class="pa-4">
                        <MudText Typo="@Typo.subtitle1"
                                 Color="@Color.Primary">
                            Backup
                        </MudText>
                        <MudSwitch T="@bool"
                                   Value="@isAutoBackupEnabled"
                                   Color="@Color.Primary"
                                   Label="Auto-backup on load"
                                   title="Automatically create a backup each time a save file is loaded"
                                   ValueChanged="@(v => OnToggle(v, x => isAutoBackupEnabled = x))"/>
                        <MudNumericField @bind-Value="@maxBackupCount"
                                         Label="Max backups to keep"
                                         Variant="@Variant.Outlined"
                                         Min="@((int)1)"
                                         Max="@((int)50)"/>
                        <MudText Typo="@Typo.caption"
                                 Color="@Color.Secondary">
                            Backups are stored in the browser. Oldest backups are automatically
                            removed when the limit is exceeded.
                        </MudText>

                        <MudDivider/>

                        <MudText Typo="@Typo.subtitle1"
                                 Color="@Color.Primary">
                            App Cache
                        </MudText>
                        <MudText Typo="@Typo.caption"
                                 Color="@Color.Secondary">
                            Use this if the app appears stuck on an old version after a deploy —
                            stale descriptions, sprites, or move data. Unregisters the service
                            worker, deletes all browser caches, and reloads the page. Your save
                            files and backups are preserved.
                        </MudText>
                        <MudButton StartIcon="@Icons.Material.Filled.DeleteSweep"
                                   Variant="@Variant.Filled"
                                   Color="@Color.Error"
                                   OnClick="@OnClearAppCache">
                            Clear App Cache &amp; Reload
                        </MudButton>
                    </MudStack>
                </MudTabPanel>
            }

        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@OnResetAll"
                   Variant="@Variant.Filled"
                   Color="@Color.Error"
                   StartIcon="@Icons.Material.Filled.RestartAlt">
            Reset All
        </MudButton>
        <MudSpacer/>
        <MudButton OnClick="@Cancel"
                   Variant="@Variant.Filled"
                   Color="@Color.Default">
            Cancel
        </MudButton>
        <MudButton OnClick="@Save"
                   Variant="@Variant.Filled"
                   Color="@Color.Primary">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>
