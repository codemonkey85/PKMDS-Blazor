@inherits BasePkmdsComponent

<MudDialog>
    <TitleContent>
        <MudText Typo="@Typo.h6">Donut Editor</MudText>
    </TitleContent>
    <DialogContent>
        @if (SaveFile is not null)
        {
            @* ── Slot navigation ── *@
            <MudStack Row
                      AlignItems="@AlignItems.Center"
                      Spacing="2"
                      Class="mb-3">
                <MudNumericField T="@int"
                                 Label="Slot"
                                 Value="@_selectedRawIndex"
                                 ValueChanged="@((int i) => _selectedRawIndex = i)"
                                 Min="0"
                                 Max="@(DonutPocket9a.MaxCount - 1)"
                                 Style="max-width:90px;"
                                 Variant="@Variant.Outlined"/>
                <MudIconButton Icon="@Icons.Material.Filled.NavigateBefore"
                               Size="@Size.Small"
                               OnClick="@GotoPrev"
                               Disabled="@(_activeIndices.IndexOf(_selectedRawIndex) <= 0)"/>
                <MudIconButton Icon="@Icons.Material.Filled.NavigateNext"
                               Size="@Size.Small"
                               OnClick="@GotoNext"
                               Disabled="@(_activeIndices.IndexOf(_selectedRawIndex) >= _activeIndices.Count - 1)"/>
                <MudText Typo="@Typo.body2">@_activeIndices.Count active donut@(_activeIndices.Count != 1 ? "s" : string.Empty)</MudText>
            </MudStack>

            @if (IsCurrentSlotOccupied && CurrentDonut is { } d)
            {
                @* ── Editor ── *@
                <MudGrid Spacing="3">

                    @* Left column: 8 berry selects *@
                    <MudItem xs="12" sm="6">
                        <MudText Typo="@Typo.subtitle2"
                                 Class="mb-1">Berries</MudText>
                        @for (var s = 0; s < 8; s++)
                        {
                            var slot = s;
                            <MudSelect T="@ushort"
                                       Label="@($"Berry {slot + 1}")"
                                       Value="@GetBerry(d, slot)"
                                       ValueChanged="@(v => { SetBerry(d, slot, v); StateHasChanged(); })"
                                       Dense
                                       Variant="@Variant.Outlined"
                                       Class="mb-1">
                                @foreach (var (item, label) in _berryOptions)
                                {
                                    <MudSelectItem Value="@item">@label</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudItem>

                    @* Right column: flavor perks + stats *@
                    <MudItem xs="12" sm="6">
                        <MudText Typo="@Typo.subtitle2"
                                 Class="mb-1">Flavor Perks</MudText>
                        @for (var s = 0; s < 3; s++)
                        {
                            var slot = s;
                            <MudSelect T="@ulong"
                                       Label="@($"Perk {slot + 1}")"
                                       Value="@GetFlavor(d, slot)"
                                       ValueChanged="@(v => { SetFlavor(d, slot, v); StateHasChanged(); })"
                                       Dense
                                       Variant="@Variant.Outlined"
                                       Class="mb-1">
                                @foreach (var (hash, name) in FlavorOptions)
                                {
                                    <MudSelectItem Value="@hash">@name</MudSelectItem>
                                }
                            </MudSelect>
                        }

                        <MudDivider Class="my-3"/>

                        <MudText Typo="@Typo.subtitle2"
                                 Class="mb-2">Stats</MudText>
                        <MudStack Row
                                  Wrap="@Wrap.Wrap"
                                  Spacing="2"
                                  Class="mb-2">
                            <MudNumericField T="@byte"
                                             Label="Stars"
                                             Value="@d.Stars"
                                             ValueChanged="@(v => d.Stars = v)"
                                             Min="0"
                                             Max="5"
                                             Variant="@Variant.Outlined"
                                             Style="max-width:90px;"/>
                            <MudNumericField T="@ushort"
                                             Label="Calories"
                                             Value="@d.Calories"
                                             ValueChanged="@(v => d.Calories = v)"
                                             Min="0"
                                             Max="9999"
                                             Variant="@Variant.Outlined"
                                             Style="max-width:110px;"/>
                            <MudNumericField T="@byte"
                                             Label="Level Boost"
                                             Value="@d.LevelBoost"
                                             ValueChanged="@(v => d.LevelBoost = v)"
                                             Min="0"
                                             Max="255"
                                             Variant="@Variant.Outlined"
                                             Style="max-width:110px;"/>
                        </MudStack>
                        <MudButton Size="@Size.Small"
                                   Variant="@Variant.Outlined"
                                   Color="@Color.Primary"
                                   OnClick="@Recalculate"
                                   Class="mb-3">
                            Recalculate Stats from Berries
                        </MudButton>

                        <MudDivider Class="my-3"/>

                        <MudText Typo="@Typo.subtitle2"
                                 Class="mb-2">Other Fields</MudText>
                        <MudStack Row
                                  Wrap="@Wrap.Wrap"
                                  Spacing="2"
                                  Class="mb-2">
                            <MudNumericField T="@ushort"
                                             Label="Donut ID"
                                             Value="@d.Donut"
                                             ValueChanged="@(v => d.Donut = v)"
                                             Min="0"
                                             Max="202"
                                             Variant="@Variant.Outlined"
                                             Style="max-width:110px;"/>
                            <MudNumericField T="@ushort"
                                             Label="Berry Name ID"
                                             Value="@d.BerryName"
                                             ValueChanged="@(v => d.BerryName = v)"
                                             Min="0"
                                             Variant="@Variant.Outlined"
                                             Style="max-width:130px;"/>
                        </MudStack>
                        <MudText Typo="@Typo.caption">Created: @FormatTimestamp(d.MillisecondsSince1970)</MudText>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudText Typo="@Typo.body2"
                         Class="my-4">Slot @_selectedRawIndex is empty.</MudText>
            }

            <MudDivider Class="mt-4 mb-3"/>

            @* ── Bulk actions ── *@
            <MudText Typo="@Typo.subtitle2"
                     Class="mb-2">Bulk Actions</MudText>
            <MudStack Row
                      Wrap="@Wrap.Wrap"
                      Spacing="2">
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Default"
                           OnClick="@Compress">
                    Compress
                </MudButton>
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Primary"
                           OnClick="@SetAllShinyTemplate">
                    Shiny Template (All 999)
                </MudButton>
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Secondary"
                           OnClick="@SetAllRandomLv3">
                    Random Lv3 (All 999)
                </MudButton>
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Info"
                           Disabled="@(!IsCurrentSlotOccupied)"
                           OnClick="@CloneSelected">
                    Clone Selected to All
                </MudButton>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudSpacer/>
        <MudButton OnClick="@Cancel"
                   Variant="@Variant.Filled"
                   Color="@Color.Default">
            Cancel
        </MudButton>
        <MudButton OnClick="@Save"
                   Variant="@Variant.Filled"
                   Color="@Color.Primary">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>
