@inherits RefreshAwareComponent

@if (AppState is not { SaveFile: { } saveFile })
{
    @if (AppState.ShowProgressIndicator)
    {
        @* Mirror the eventual layout (save title row → tabs bar → content panel)
           so the skeleton lands where boxes will render rather than collapsing
           into a small top-left stack. *@
        <MudStack Spacing="3"
                  Class="save-file-loading-skeleton">
            <MudSkeleton SkeletonType="@SkeletonType.Text"
                         Width="40%"
                         Height="40px"/>
            <MudSkeleton SkeletonType="@SkeletonType.Rectangle"
                         Width="100%"
                         Height="48px"/>
            <MudSkeleton SkeletonType="@SkeletonType.Rectangle"
                         Width="100%"
                         Height="420px"/>
        </MudStack>
    }
}
else
{
    <PageTitle>
        @SaveFileNameDisplay.SaveFileNameDisplayString(AppState, AppService, true)
    </PageTitle>

    <MudText Typo="@Typo.h5">
        @SaveFileNameDisplay.SaveFileNameDisplayString(AppState, AppService)
    </MudText>

    <MudTabs Outlined
             Rounded
             Border
             Class="save-file-outer-tabs"
             @bind-ActivePanelIndex="@activeTabIndex">

        <MudTabPanel Text="Party / Box">
            <div class="mt-3 party-box-tab-content">
                <PartyAndBoxTab/>
            </div>
        </MudTabPanel>

        <MudTabPanel Text="Trainer">
            <div class="mt-3">
                <TrainerInfoTab/>
            </div>
        </MudTabPanel>

        <MudTabPanel Text="Bag">
            <div class="mt-3">
                <BagTab Inventory="@AppState.SaveFile.Inventory"/>
            </div>
        </MudTabPanel>

        @if (saveFile.Generation >= 4)
        {
            <MudTabPanel Text="Mystery Gifts">
                <div class="mt-3">
                    <MysteryGiftDatabaseTab/>
                </div>
            </MudTabPanel>
        }

        @if (AppService.HasWonderCardSlots())
        {
            <MudTabPanel Text="Wonder Cards">
                <div class="mt-3">
                    <WonderCardsTab/>
                </div>
            </MudTabPanel>
        }

        @if (saveFile is SAV3 { Generation: 3 } sav3)
        {
            <MudTabPanel Text="Records">
                <RecordsTab SaveFile="@sav3"/>
            </MudTabPanel>
        }

        @if (saveFile is SAV3RS or SAV3E or SAV4Sinnoh or SAV8BS)
        {
            <MudTabPanel Text="Feebas">
                <div class="mt-3 feebas-tab-content">
                    <FeebasLocatorTab/>
                </div>
            </MudTabPanel>
        }

        @if (saveFile.HasPokeDex)
        {
            <MudTabPanel Text="Pokédex">
                <PokedexTab/>
            </MudTabPanel>
        }

        @if (AppService.HasBattleBox() || AppService.HasBattleTeams() || AppService.HasRentalTeams())
        {
            <MudTabPanel Text="Teams">
                <div class="mt-3 teams-tab-content">
                    <TeamsTab/>
                </div>
            </MudTabPanel>
        }

        <MudTabPanel Text="Legality Report">
            <div class="mt-3">
                <LegalityReportTab OnJumpToPartyBox="@JumpToPartyBox"/>
            </div>
        </MudTabPanel>

        <MudTabPanel Text="Search">
            <div class="mt-3">
                <AdvancedSearchTab OnJumpToPartyBox="@JumpToPartyBox"/>
            </div>
        </MudTabPanel>

        <MudTabPanel Text="Encounter DB">
            <div class="mt-3">
                <EncounterDatabaseTab OnJumpToPartyBox="@JumpToPartyBox"/>
            </div>
        </MudTabPanel>

        <MudTabPanel Text="Batch Editor">
            <div class="mt-3">
                <BatchEditorTab/>
            </div>
        </MudTabPanel>

        @if (!HostService.IsEmbedded)
        {
            <MudTabPanel Text="Pokémon Bank">
                <div class="mt-3 bank-tab-content">
                    <PokemonBankTab/>
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Trade">
                <div class="mt-3 trade-tab-content">
                    <TradeTab/>
                </div>
            </MudTabPanel>
        }

    </MudTabs>
}
