@inherits RefreshAwareComponent

<MudStack Class="pa-2"
          Spacing="3">

    @if (AppState.SaveFile is null)
    {
        <MudAlert Severity="@Severity.Info">No save file is loaded.</MudAlert>
    }
    else
    {
        <MudGrid>

            @* ── Filter panel ── *@
            <MudItem xs="12"
                     md="5">
                <MudStack Spacing="2"
                          Class="search-filter-panel">

                    <div class="search-filter-panel-scroll">

                        <MudExpansionPanels MultiExpansion
                                            Dense>

                            @* ── Basic ── *@
                            <MudExpansionPanel Text="Search">
                                <MudStack Spacing="2">

                                    @* Species (required to search) *@
                                    <MudAutocomplete T="@ComboItem"
                                                     Label="Species (required)"
                                                     Value="@speciesItem"
                                                     ValueChanged="@(v => speciesItem = v)"
                                                     SearchFunc="@SearchSpeciesAsync"
                                                     ToStringFunc="@SpeciesItemToString"
                                                     Clearable
                                                     ResetValueOnEmptyText/>

                                    @* Game version *@
                                    <AutocompleteSelect T="@(int?)"
                                                        Label="Game version"
                                                        @bind-Value="@gameVersionValue"
                                                        Items="@GameVersionFilterItems"
                                                        ToStringFunc="@GameVersionFilterText"/>

                                </MudStack>
                            </MudExpansionPanel>

                            @* ── Filters ── *@
                            <MudExpansionPanel Text="Filters">
                                <MudStack Spacing="2">

                                    @* Level range *@
                                    <MudText Typo="@Typo.subtitle2">Level range</MudText>
                                    <MudGrid Spacing="2">
                                        <MudItem xs="6">
                                            <MudNumericField T="@(int?)"
                                                             Label="Min level"
                                                             @bind-Value="@levelMin"
                                                             Min="1"
                                                             Max="100"/>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudNumericField T="@(int?)"
                                                             Label="Max level"
                                                             @bind-Value="@levelMax"
                                                             Min="1"
                                                             Max="100"/>
                                        </MudItem>
                                    </MudGrid>

                                    @* Shiny lock *@
                                    <AutocompleteSelect T="@(bool?)"
                                                        Label="Shiny lock"
                                                        @bind-Value="@isShinyLocked"
                                                        Items="@ShinyLockFilterItems"
                                                        ToStringFunc="@ShinyLockFilterText"/>

                                    @* Encounter type *@
                                    <AutocompleteSelect T="@(int?)"
                                                        Label="Encounter type"
                                                        @bind-Value="@encounterGroupValue"
                                                        Items="@EncounterGroupFilterItems"
                                                        ToStringFunc="@EncounterGroupFilterText"/>

                                </MudStack>
                            </MudExpansionPanel>

                        </MudExpansionPanels>

                        @* ── Selected encounter detail ── *@
                        @if (selectedResult is { } sel)
                        {
                            <MudPaper Outlined
                                      Class="pa-3">
                                <MudStack Spacing="2">

                                    <MudText Typo="@Typo.subtitle1">
                                        <strong>@sel.SpeciesName</strong>
                                        &nbsp;–&nbsp;@sel.EncounterTypeName
                                    </MudText>

                                    <MudText Typo="@Typo.body2">@sel.Encounter.LongName</MudText>

                                    <MudGrid Spacing="1">
                                        <MudItem xs="6">
                                            <MudText Typo="@Typo.caption">Game</MudText>
                                            <MudText Typo="@Typo.body2">@sel.GameName</MudText>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudText Typo="@Typo.caption">Level</MudText>
                                            <MudText Typo="@Typo.body2">@sel.LevelRange</MudText>
                                        </MudItem>
                                        @if (sel.Location is not null)
                                        {
                                            <MudItem xs="12">
                                                <MudText Typo="@Typo.caption">Location</MudText>
                                                <MudText Typo="@Typo.body2">@sel.Location</MudText>
                                            </MudItem>
                                        }
                                        <MudItem xs="6">
                                            <MudText Typo="@Typo.caption">Shiny</MudText>
                                            <MudText Typo="@Typo.body2">
                                                @(sel.IsShinyLocked
                                                    ? "Locked (never shiny)"
                                                    : sel.Encounter.Shiny.ToString())
                                            </MudText>
                                        </MudItem>
                                    </MudGrid>

                                    @if (sel.IsMysteryGift)
                                    {
                                        <MudAlert Severity="@Severity.Info"
                                                  Dense>
                                            This is a Mystery Gift encounter. See the Mystery Gifts tab to import the
                                            gift
                                            data directly.
                                        </MudAlert>
                                    }

                                    <MudButton Variant="@Variant.Filled"
                                               Color="@Color.Success"
                                               StartIcon="@Icons.Material.Filled.CatchingPokemon"
                                               OnClick="@GeneratePokemonAsync"
                                               Disabled="@isGenerating">
                                        @(isGenerating
                                            ? "Generating…"
                                            : "Generate Pokémon")
                                    </MudButton>

                                </MudStack>
                            </MudPaper>
                        }

                    </div>

                    @* Action buttons *@
                    <MudStack Row
                              Spacing="2"
                              Class="search-filter-panel-actions">
                        <MudButton Variant="@Variant.Filled"
                                   Color="@Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="@RunSearchAsync"
                                   Disabled="@(isSearching || speciesItem is null || speciesItem?.Value <= 0)">
                            @(isSearching
                                ? "Searching…"
                                : "Search")
                        </MudButton>

                        @if (isSearching)
                        {
                            <MudProgressCircular Indeterminate
                                                 Size="@Size.Small"
                                                 Color="@Color.Primary"/>
                        }

                        <MudButton Variant="@Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Clear"
                                   OnClick="@ResetFilter"
                                   Disabled="@isSearching">
                            Reset
                        </MudButton>
                    </MudStack>

                </MudStack>
            </MudItem>

            @* ── Results panel ── *@
            <MudItem xs="12"
                     md="7">
                <MudStack Spacing="2">

                    @if (HasResults)
                    {
                        <MudChip T="@string"
                                 Color="@Color.Default"
                                 Variant="@Variant.Outlined"
                                 Size="@Size.Small">
                            @ResultCount encounter@(ResultCount == 1
                                                          ? string.Empty
                                                          : "s") found
                        </MudChip>
                    }

                    <MudTable T="@EncounterSearchResult"
                              Items="@results"
                              Dense
                              Hover
                              Bordered
                              FixedHeader
                              Height="calc(100dvh - 280px - var(--pkmds-safe-area-top))"
                              @bind-SelectedItem="@selectedResult"
                              SortLabel="Sort By"
                              OnRowClick="@OnRowClickAsync"
                              RowStyleFunc="@RowStyleFunc"
                              RowsPerPage="25"
                              Class="encounter-db-table">

                        <HeaderContent>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<EncounterSearchResult, object>(r => r.SpeciesName))">
                                    Species
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<EncounterSearchResult, object>(r => r.GameName))">
                                    Game
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<EncounterSearchResult, object>(r => r.EncounterTypeName))">
                                    Type
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<EncounterSearchResult, object>(r => r.Encounter.LevelMin))">
                                    Level
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>Shiny Lock</MudTh>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<EncounterSearchResult, object>(r => r.Location ?? string.Empty))">
                                    Location
                                </MudTableSortLabel>
                            </MudTh>

                        </HeaderContent>

                        <RowTemplate>

                            <MudTd DataLabel="Species">@context.SpeciesName</MudTd>

                            <MudTd DataLabel="Game">@context.GameName</MudTd>

                            <MudTd DataLabel="Type">
                                <MudChip T="@string"
                                         Size="@Size.Small"
                                         Color="@GetTypeChipColor(context.EncounterTypeName)"
                                         Variant="@Variant.Outlined">
                                    @context.EncounterTypeName
                                </MudChip>
                            </MudTd>

                            <MudTd DataLabel="Level">@context.LevelRange</MudTd>

                            <MudTd DataLabel="Shiny Lock">
                                @if (context.IsShinyLocked)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Lock"
                                             Color="@Color.Error"
                                             Size="@Size.Small"
                                             Title="Shiny locked"/>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.LockOpen"
                                             Color="@Color.Success"
                                             Size="@Size.Small"
                                             Title="Can be shiny"/>
                                }
                            </MudTd>

                            <MudTd DataLabel="Location">@(context.Location ?? "—")</MudTd>

                        </RowTemplate>

                        <NoRecordsContent>
                            @if (isSearching)
                            {
                                <MudText>Searching…</MudText>
                            }
                            else if (!hasSearched)
                            {
                                <MudText>Select a species and run a search to see encounters.</MudText>
                            }
                            else
                            {
                                <MudText>No encounters match the current filter.</MudText>
                            }
                        </NoRecordsContent>

                        <PagerContent>
                            <MudTablePager/>
                        </PagerContent>

                    </MudTable>

                </MudStack>
            </MudItem>

        </MudGrid>
    }

</MudStack>
