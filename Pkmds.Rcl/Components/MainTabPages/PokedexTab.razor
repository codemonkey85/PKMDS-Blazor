@inherits BasePkmdsComponent

@if (AppState.SaveFile is { HasPokeDex: true })
{
    <MudStack>
        <MudText Typo="@Typo.body2">Seen: @displaySeenCount / @dexTotal</MudText>
        <MudProgressLinear Color="@Color.Info"
                           Value="@seenPercent"/>

        <MudText Typo="@Typo.body2">Caught: @displayCaughtCount / @dexTotal</MudText>
        <MudProgressLinear Color="@Color.Success"
                           Value="@caughtPercent"/>

        <MudStack Row="true"
                  Wrap="@Wrap.Wrap">
            <MudButton OnClick="@FillPokedex"
                       Variant="@Variant.Filled"
                       Color="@Color.Primary"
                       StartIcon="">
                Fill Pokédex
            </MudButton>

            <MudButton OnClick="@SeenAllPokedex"
                       Variant="@Variant.Filled"
                       Color="@Color.Secondary"
                       StartIcon=""
                       Disabled="@IsLegendArceus">
                Seen All
            </MudButton>

            <MudButton OnClick="@ClearPokedex"
                       Variant="@Variant.Filled"
                       Color="@Color.Error"
                       StartIcon=""
                       Disabled="@IsLegendArceus">
                Clear Pokédex
            </MudButton>
        </MudStack>
    </MudStack>
}
