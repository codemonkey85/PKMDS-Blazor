@inherits BasePkmdsComponent

@if (AppState.SaveFile is SAV9SV sav9sv)
{
    @if (sav9sv.Zukan.GetRevision() == (int)DexBlockMode9.Paldea)
    {
        @* ── Paldea-mode (base game, no DLC patch) ── uses DexPaldea / PokeDexEntry9Paldea *@
        var dex = sav9sv.Zukan.DexPaldea;
        var formCount = sav9sv.Personal.GetFormEntry(SpeciesId, 0).FormCount;
        var formNames = FormConverter.GetFormList(SpeciesId, GameInfo.Strings.types, GameInfo.Strings.forms,
            GameInfo.GenderSymbolASCII, EntityContext.Gen9);

        <MudStack Spacing="3">

            @* Quick actions *@
            <MudStack Row
                      Spacing="2">
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Primary"
                           OnClick="@(() => { dex.SetDexEntryAll(SpeciesId); StateHasChanged(); })">
                    Fill Entry
                </MudButton>
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Secondary"
                           OnClick="@(() => { dex.SetDexEntryAll(SpeciesId, true); StateHasChanged(); })">
                    Fill Entry (Shiny)
                </MudButton>
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Error"
                           OnClick="@(() => { dex.ClearDexEntryAll(SpeciesId); StateHasChanged(); })">
                    Clear Entry
                </MudButton>
            </MudStack>

            @* State *@
            <MudSelect T="@uint"
                       Label="State"
                       Value="@dex.Get(SpeciesId).GetState()"
                       ValueChanged="@(v =>
                                     {
                                         dex.Get(SpeciesId).SetState(v);
                                         StateHasChanged();
                                     })"
                       Dense
                       Style="max-width:200px;">
                <MudSelectItem Value="@(0u)">Unknown</MudSelectItem>
                <MudSelectItem Value="@(1u)">Shown</MudSelectItem>
                <MudSelectItem Value="@(2u)">Seen</MudSelectItem>
                <MudSelectItem Value="@(3u)">Obtained</MudSelectItem>
            </MudSelect>

            @* Gender / shiny seen *@
            <MudText Typo="@Typo.subtitle2">Gender / Shiny Seen</MudText>
            <MudStack Row
                      Spacing="2">
                <MudCheckBox T="@bool"
                             Label="Male"
                             Disabled="@(!IsGenderAvailable(sav9sv, SpeciesId, 0))"
                             Value="@dex.Get(SpeciesId).GetIsGenderSeen(0)"
                             ValueChanged="@(v =>
                                           {
                                               dex.Get(SpeciesId).SetIsGenderSeen(0, v);
                                               StateHasChanged();
                                           })"/>
                <MudCheckBox T="@bool"
                             Label="Female"
                             Disabled="@(!IsGenderAvailable(sav9sv, SpeciesId, 1))"
                             Value="@dex.Get(SpeciesId).GetIsGenderSeen(1)"
                             ValueChanged="@(v =>
                                           {
                                               dex.Get(SpeciesId).SetIsGenderSeen(1, v);
                                               StateHasChanged();
                                           })"/>
                <MudCheckBox T="@bool"
                             Label="Genderless"
                             Disabled="@(!IsGenderAvailable(sav9sv, SpeciesId, 2))"
                             Value="@dex.Get(SpeciesId).GetIsGenderSeen(2)"
                             ValueChanged="@(v =>
                                           {
                                               dex.Get(SpeciesId).SetIsGenderSeen(2, v);
                                               StateHasChanged();
                                           })"/>
                <MudCheckBox T="@bool"
                             Label="Shiny Seen"
                             Value="@dex.Get(SpeciesId).GetSeenIsShiny()"
                             ValueChanged="@(v =>
                                           {
                                               dex.Get(SpeciesId).SetSeenIsShiny(v);
                                               StateHasChanged();
                                           })"/>
            </MudStack>

            @* Forms seen *@
            @if (formCount > 1)
            {
                <MudText Typo="@Typo.subtitle2">Forms Seen</MudText>
                <MudSimpleTable Dense
                                Style="max-width:300px;">
                    <thead>
                    <tr>
                        <th>Form</th>
                        <th>Seen</th>
                    </tr>
                    </thead>
                    <tbody>
                    @for (byte i = 0; i < formNames.Length; i++)
                    {
                        var fi = i;
                        var name = formNames[fi].Length > 0
                            ? formNames[fi]
                            : GameInfo.Strings.Types[0];
                        <tr>
                            <td>@name</td>
                            <td>
                                <MudCheckBox T="@bool"
                                             Value="@dex.Get(SpeciesId).GetIsFormSeen(fi)"
                                             ValueChanged="@(v =>
                                                           {
                                                               dex.Get(SpeciesId).SetIsFormSeen(fi, v);
                                                               StateHasChanged();
                                                           })"/>
                            </td>
                        </tr>
                    }
                    </tbody>
                </MudSimpleTable>
            }

            @* Display *@
            <MudText Typo="@Typo.subtitle2">Display</MudText>
            <MudStack Row
                      Spacing="2"
                      AlignItems="AlignItems.Center">
                @if (formCount > 1)
                {
                    <MudSelect T="@uint"
                               Label="Form"
                               Value="@dex.Get(SpeciesId).GetDisplayForm()"
                               ValueChanged="@(v =>
                                             {
                                                 dex.Get(SpeciesId).SetDisplayForm(v);
                                                 StateHasChanged();
                                             })"
                               Dense
                               Style="max-width:140px;">
                        @for (uint fi = 0; fi < (uint)formNames.Length; fi++)
                        {
                            var fiv = fi;
                            var fn = formNames[fiv].Length > 0
                                ? formNames[fiv]
                                : GameInfo.Strings.Types[0];
                            <MudSelectItem Value="@fiv">@fn</MudSelectItem>
                        }
                    </MudSelect>
                }
                <MudSelect T="@uint"
                           Label="Gender"
                           Value="@dex.Get(SpeciesId).GetDisplayGender()"
                           ValueChanged="@(v =>
                                         {
                                             dex.Get(SpeciesId).SetDisplayGender((int)v);
                                             StateHasChanged();
                                         })"
                           Dense
                           Style="max-width:140px;">
                    <MudSelectItem Value="@(0u)">Male</MudSelectItem>
                    <MudSelectItem Value="@(1u)">Female</MudSelectItem>
                    <MudSelectItem Value="@(2u)">Genderless</MudSelectItem>
                </MudSelect>
                <MudCheckBox T="@bool"
                             Label="Shiny"
                             Value="@dex.Get(SpeciesId).GetDisplayIsShiny()"
                             ValueChanged="@(v =>
                                           {
                                               dex.Get(SpeciesId).SetDisplayIsShiny(v);
                                               StateHasChanged();
                                           })"/>
                <MudCheckBox T="@bool"
                             Label="New"
                             Value="@dex.Get(SpeciesId).GetDisplayIsNew()"
                             ValueChanged="@(v =>
                                           {
                                               dex.Get(SpeciesId).SetDisplayIsNew(v);
                                               StateHasChanged();
                                           })"/>
            </MudStack>

            @* Language flags *@
            <MudText Typo="@Typo.subtitle2">Languages Obtained</MudText>
            <MudStack Row
                      Wrap="@Wrap.Wrap"
                      Spacing="1">
                @foreach (var (label, langId) in LanguageLabels)
                {
                    var lid = langId;
                    <MudCheckBox T="@bool"
                                 Label="@label"
                                 Value="@dex.Get(SpeciesId).GetLanguageFlag(lid)"
                                 ValueChanged="@(v =>
                                               {
                                                   dex.Get(SpeciesId).SetLanguageFlag(lid, v);
                                                   StateHasChanged();
                                               })"/>
                }
            </MudStack>

        </MudStack>
    }
    else
    {
        @* ── Kitakami-mode (DLC 2.0.1+) ── unified block (DexKitakami) stores all species *@
        var dexKita = sav9sv.Zukan.DexKitakami;
        var formCount = sav9sv.Personal.GetFormEntry(SpeciesId, 0).FormCount;
        var formNames = FormConverter.GetFormList(SpeciesId, GameInfo.Strings.types, GameInfo.Strings.forms,
            GameInfo.GenderSymbolASCII, EntityContext.Gen9);
        var (inPaldea, inKitakami, inBlueberry) = GetDexMembership(sav9sv, SpeciesId);

        <MudStack Spacing="3">

            @* Quick actions *@
            <MudStack Row
                      Spacing="2">
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Primary"
                           OnClick="@(() => { dexKita.SetDexEntryAll(SpeciesId); StateHasChanged(); })">
                    Fill Entry
                </MudButton>
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Secondary"
                           OnClick="@(() => { dexKita.SetDexEntryAll(SpeciesId, true); StateHasChanged(); })">
                    Fill Entry (Shiny)
                </MudButton>
                <MudButton Size="@Size.Small"
                           Variant="@Variant.Filled"
                           Color="@Color.Error"
                           OnClick="@(() => { dexKita.ClearDexEntryAll(SpeciesId); StateHasChanged(); })">
                    Clear Entry
                </MudButton>
            </MudStack>

            @* Per-form flags *@
            @if (formCount > 0)
            {
                <MudText Typo="@Typo.subtitle2">Form Flags</MudText>
                <MudSimpleTable Dense
                                Style="max-width:460px; max-height:240px; overflow-y:auto;">
                    <thead>
                    <tr>
                        <th>Form</th>
                        <th>Seen</th>
                        <th>Obtained</th>
                        <th>Heard</th>
                        <th>Checked</th>
                    </tr>
                    </thead>
                    <tbody>
                    @for (byte fi = 0; fi < sizeof(uint) * 8; fi++)
                    {
                        var f = fi;
                        var name = f < formNames.Length
                            ? formNames[f].Length > 0
                                ? formNames[f]
                                : GameInfo.Strings.Types[0]
                            : $"--{f:00}--";
                        <tr>
                            <td>@name</td>
                            <td>
                                <MudCheckBox T="@bool"
                                             Value="@dexKita.Get(SpeciesId).GetSeenForm(f)"
                                             ValueChanged="@(v =>
                                                           {
                                                               dexKita.Get(SpeciesId).SetSeenForm(f, v);
                                                               StateHasChanged();
                                                           })"/>
                            </td>
                            <td>
                                <MudCheckBox T="@bool"
                                             Value="@dexKita.Get(SpeciesId).GetObtainedForm(f)"
                                             ValueChanged="@(v =>
                                                           {
                                                               dexKita.Get(SpeciesId).SetObtainedForm(f, v);
                                                               StateHasChanged();
                                                           })"/>
                            </td>
                            <td>
                                <MudCheckBox T="@bool"
                                             Value="@dexKita.Get(SpeciesId).GetHeardForm(f)"
                                             ValueChanged="@(v =>
                                                           {
                                                               dexKita.Get(SpeciesId).SetHeardForm(f, v);
                                                               StateHasChanged();
                                                           })"/>
                            </td>
                            <td>
                                <MudCheckBox T="@bool"
                                             Value="@dexKita.Get(SpeciesId).GetCheckedForm(f)"
                                             ValueChanged="@(v =>
                                                           {
                                                               dexKita.Get(SpeciesId).SetCheckedForm(f, v);
                                                               StateHasChanged();
                                                           })"/>
                            </td>
                        </tr>
                    }
                    </tbody>
                </MudSimpleTable>
            }

            @* Gender / Shiny Seen *@
            <MudText Typo="@Typo.subtitle2">Gender / Shiny Seen</MudText>
            <MudStack Row
                      Spacing="2">
                <MudCheckBox T="@bool"
                             Label="Male"
                             Disabled="@(!IsGenderAvailable(sav9sv, SpeciesId, 0))"
                             Value="@dexKita.Get(SpeciesId).GetIsGenderSeen(0)"
                             ValueChanged="@(v =>
                                           {
                                               dexKita.Get(SpeciesId).SetIsGenderSeen(0, v);
                                               StateHasChanged();
                                           })"/>
                <MudCheckBox T="@bool"
                             Label="Female"
                             Disabled="@(!IsGenderAvailable(sav9sv, SpeciesId, 1))"
                             Value="@dexKita.Get(SpeciesId).GetIsGenderSeen(1)"
                             ValueChanged="@(v =>
                                           {
                                               dexKita.Get(SpeciesId).SetIsGenderSeen(1, v);
                                               StateHasChanged();
                                           })"/>
                <MudCheckBox T="@bool"
                             Label="Genderless"
                             Disabled="@(!IsGenderAvailable(sav9sv, SpeciesId, 2))"
                             Value="@dexKita.Get(SpeciesId).GetIsGenderSeen(2)"
                             ValueChanged="@(v =>
                                           {
                                               dexKita.Get(SpeciesId).SetIsGenderSeen(2, v);
                                               StateHasChanged();
                                           })"/>
                <MudCheckBox T="@bool"
                             Label="Shiny Seen"
                             Value="@dexKita.Get(SpeciesId).GetIsModelSeen(true)"
                             ValueChanged="@(v =>
                                           {
                                               dexKita.Get(SpeciesId).SetIsModelSeen(true, v);
                                               StateHasChanged();
                                           })"/>
            </MudStack>

            @* Language flags *@
            <MudText Typo="@Typo.subtitle2">Languages Obtained</MudText>
            <MudStack Row
                      Wrap="@Wrap.Wrap"
                      Spacing="1">
                @foreach (var (label, langId) in LanguageLabels)
                {
                    var lid = langId;
                    <MudCheckBox T="@bool"
                                 Label="@label"
                                 Value="@dexKita.Get(SpeciesId).GetLanguageFlag(lid)"
                                 ValueChanged="@(v =>
                                               {
                                                   dexKita.Get(SpeciesId).SetLanguageFlag(lid, v);
                                                   StateHasChanged();
                                               })"/>
                }
            </MudStack>

            @* Per-regional-dex display options *@
            <MudText Typo="@Typo.subtitle2">Display</MudText>

            @if (inPaldea)
            {
                <MudText Typo="@Typo.caption">Paldea</MudText>
                <MudStack Row
                          Spacing="2"
                          AlignItems="AlignItems.Center">
                    @if (formCount > 1)
                    {
                        <MudSelect T="@byte"
                                   Label="Form"
                                   Value="@dexKita.Get(SpeciesId).DisplayedPaldeaForm"
                                   ValueChanged="@(v => SetKitakamiDisplayPaldea(dexKita, SpeciesId, v, dexKita.Get(SpeciesId).DisplayedPaldeaGender, dexKita.Get(SpeciesId).DisplayedPaldeaShiny))"
                                   Dense
                                   Style="max-width:140px;">
                            @for (byte fi = 0; fi < formNames.Length; fi++)
                            {
                                var fiv = fi;
                                var fn = formNames[fiv].Length > 0
                                    ? formNames[fiv]
                                    : GameInfo.Strings.Types[0];
                                <MudSelectItem Value="@fiv">@fn</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    <MudSelect T="@byte"
                               Label="Gender"
                               Value="@dexKita.Get(SpeciesId).DisplayedPaldeaGender"
                               ValueChanged="@(v => SetKitakamiDisplayPaldea(dexKita, SpeciesId, dexKita.Get(SpeciesId).DisplayedPaldeaForm, v, dexKita.Get(SpeciesId).DisplayedPaldeaShiny))"
                               Dense
                               Style="max-width:140px;">
                        <MudSelectItem Value="@((byte)0)">Male</MudSelectItem>
                        <MudSelectItem Value="@((byte)1)">Female</MudSelectItem>
                        <MudSelectItem Value="@((byte)2)">Genderless</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox T="@bool"
                                 Label="Shiny"
                                 Value="@(dexKita.Get(SpeciesId).DisplayedPaldeaShiny != 0)"
                                 ValueChanged="@(v => SetKitakamiDisplayPaldea(dexKita, SpeciesId, dexKita.Get(SpeciesId).DisplayedPaldeaForm, dexKita.Get(SpeciesId).DisplayedPaldeaGender, v
                                                   ? (byte)1
                                                   : (byte)0))"/>
                </MudStack>
            }

            @if (inKitakami)
            {
                <MudText Typo="@Typo.caption">Kitakami</MudText>
                <MudStack Row
                          Spacing="2"
                          AlignItems="AlignItems.Center">
                    @if (formCount > 1)
                    {
                        <MudSelect T="@byte"
                                   Label="Form"
                                   Value="@dexKita.Get(SpeciesId).DisplayedKitakamiForm"
                                   ValueChanged="@(v => SetKitakamiDisplayKitakami(dexKita, SpeciesId, v, dexKita.Get(SpeciesId).DisplayedKitakamiGender, dexKita.Get(SpeciesId).DisplayedKitakamiShiny))"
                                   Dense
                                   Style="max-width:140px;">
                            @for (byte fi = 0; fi < formNames.Length; fi++)
                            {
                                var fiv = fi;
                                var fn = formNames[fiv].Length > 0
                                    ? formNames[fiv]
                                    : GameInfo.Strings.Types[0];
                                <MudSelectItem Value="@fiv">@fn</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    <MudSelect T="@byte"
                               Label="Gender"
                               Value="@dexKita.Get(SpeciesId).DisplayedKitakamiGender"
                               ValueChanged="@(v => SetKitakamiDisplayKitakami(dexKita, SpeciesId, dexKita.Get(SpeciesId).DisplayedKitakamiForm, v, dexKita.Get(SpeciesId).DisplayedKitakamiShiny))"
                               Dense
                               Style="max-width:140px;">
                        <MudSelectItem Value="@((byte)0)">Male</MudSelectItem>
                        <MudSelectItem Value="@((byte)1)">Female</MudSelectItem>
                        <MudSelectItem Value="@((byte)2)">Genderless</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox T="@bool"
                                 Label="Shiny"
                                 Value="@(dexKita.Get(SpeciesId).DisplayedKitakamiShiny != 0)"
                                 ValueChanged="@(v => SetKitakamiDisplayKitakami(dexKita, SpeciesId, dexKita.Get(SpeciesId).DisplayedKitakamiForm, dexKita.Get(SpeciesId).DisplayedKitakamiGender, v
                                                   ? (byte)1
                                                   : (byte)0))"/>
                </MudStack>
            }

            @if (inBlueberry)
            {
                <MudText Typo="@Typo.caption">Blueberry</MudText>
                <MudStack Row
                          Spacing="2"
                          AlignItems="AlignItems.Center">
                    @if (formCount > 1)
                    {
                        <MudSelect T="@byte"
                                   Label="Form"
                                   Value="@dexKita.Get(SpeciesId).DisplayedBlueberryForm"
                                   ValueChanged="@(v => SetKitakamiDisplayBlueberry(dexKita, SpeciesId, v, dexKita.Get(SpeciesId).DisplayedBlueberryGender, dexKita.Get(SpeciesId).DisplayedBlueberryShiny))"
                                   Dense
                                   Style="max-width:140px;">
                            @for (byte fi = 0; fi < formNames.Length; fi++)
                            {
                                var fiv = fi;
                                var fn = formNames[fiv].Length > 0
                                    ? formNames[fiv]
                                    : GameInfo.Strings.Types[0];
                                <MudSelectItem Value="@fiv">@fn</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    <MudSelect T="@byte"
                               Label="Gender"
                               Value="@dexKita.Get(SpeciesId).DisplayedBlueberryGender"
                               ValueChanged="@(v => SetKitakamiDisplayBlueberry(dexKita, SpeciesId, dexKita.Get(SpeciesId).DisplayedBlueberryForm, v, dexKita.Get(SpeciesId).DisplayedBlueberryShiny))"
                               Dense
                               Style="max-width:140px;">
                        <MudSelectItem Value="@((byte)0)">Male</MudSelectItem>
                        <MudSelectItem Value="@((byte)1)">Female</MudSelectItem>
                        <MudSelectItem Value="@((byte)2)">Genderless</MudSelectItem>
                    </MudSelect>
                    <MudCheckBox T="@bool"
                                 Label="Shiny"
                                 Value="@(dexKita.Get(SpeciesId).DisplayedBlueberryShiny != 0)"
                                 ValueChanged="@(v => SetKitakamiDisplayBlueberry(dexKita, SpeciesId, dexKita.Get(SpeciesId).DisplayedBlueberryForm, dexKita.Get(SpeciesId).DisplayedBlueberryGender, v
                                                   ? (byte)1
                                                   : (byte)0))"/>
                </MudStack>
            }

        </MudStack>
    }
}
