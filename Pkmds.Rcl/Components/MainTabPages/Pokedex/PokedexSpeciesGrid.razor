@inherits BasePkmdsComponent

@if (rows.Count > 0)
{
    <MudStack Row
              AlignItems="@AlignItems.Center"
              Wrap="@Wrap.Wrap"
              Spacing="2"
              Class="mb-2">
        <MudTextField Value="@searchText"
                      ValueChanged="@((string v) => SetSearchText(v))"
                      Placeholder="Search species…"
                      Immediate
                      AdornmenT="@Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Clearable/>
        <MudToggleGroup T="@DexStatusFilter"
                        Value="@selectedStatusFilter"
                        ValueChanged="@SetStatusFilter"
                        Color="@Color.Primary"
                        Size="@Size.Small">
            <MudToggleItem T="@DexStatusFilter"
                           Value="@DexStatusFilter.All">
                All
            </MudToggleItem>
            <MudToggleItem T="@DexStatusFilter"
                           Value="@DexStatusFilter.Seen">
                Seen
            </MudToggleItem>
            <MudToggleItem T="@DexStatusFilter"
                           Value="@DexStatusFilter.Caught">
                Caught
            </MudToggleItem>
            <MudToggleItem T="@DexStatusFilter"
                           Value="@DexStatusFilter.Unseen">
                Unseen
            </MudToggleItem>
            <MudToggleItem T="@DexStatusFilter"
                           Value="@DexStatusFilter.SeenNotCaught">
                Seen / Not Caught
            </MudToggleItem>
        </MudToggleGroup>
        @* Hide the regional-dex toggle when filtering by the single available dex would
           be a no-op — i.e. when every row already belongs to that dex (SV Rev 0, LA).
           Keep it visible when rows include species outside the single dex (BDSP, where
           the grid lists all national species but only some are in the Sinnoh dex). *@
        @if (ShowRegionalDexToggle)
        {
            <MudToggleGroup T="@int"
                            Value="@selectedRegionalDexFilter"
                            ValueChanged="@SetRegionalDexFilter"
                            Color="@Color.Primary"
                            Size="@Size.Small">
                <MudToggleItem T="@int"
                               Value="-1">
                    All Dexes
                </MudToggleItem>
                @for (var i = 0; i < regionalDexDefinitions.Count; i++)
                {
                    var idx = i;
                    <MudToggleItem T="@int"
                                   Value="@idx">
                        @regionalDexDefinitions[idx].Name
                    </MudToggleItem>
                }
            </MudToggleGroup>
        }
    </MudStack>

    <MudDataGrid T="@PokedexGridRow"
                 Items="@filteredRows"
                 Dense
                 Hover
                 Bordered
                 FixedHeader
                 Virtualize="true"
                 RowClassFunc="@((_, i) => i % 2 != 0
                                   ? "row-alt"
                                   : string.Empty)"
                 Class="pokedex-species-grid">

        <Columns>
            <PropertyColumn Property="@(r => r.SpeciesId)"
                            Title="#"/>
            @for (var col = 0; col < regionalDexDefinitions.Count; col++)
            {
                var colIdx = col;
                <TemplateColumn Title="@regionalDexDefinitions[colIdx].Name"
                                Sortable="true"
                                SortBy="@(r => RegionalIdForSort(r, colIdx))">
                    <CellTemplate>
                        @if (colIdx < context.Item.RegionalIds.Count && context.Item.RegionalIds[colIdx] != 0)
                        {
                            @context.Item.RegionalIds[colIdx]
                        }
                    </CellTemplate>
                </TemplateColumn>
            }
            <PropertyColumn Property="@(r => r.Name)"
                            Title="Species"/>
            <TemplateColumn Title="Seen"
                            Sortable="true"
                            SortBy="@(r => r.IsSeen)">
                <CellTemplate>
                    <MudCheckBox T="@bool"
                                 Value="@context.Item.IsSeen"
                                 ValueChanged="@(v => OnSeenChanged(context.Item, v))"/>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Caught"
                            Sortable="true"
                            SortBy="@(r => r.IsCaught)">
                <CellTemplate>
                    <MudCheckBox T="@bool"
                                 Value="@context.Item.IsCaught"
                                 ValueChanged="@(v => OnCaughtChanged(context.Item, v))"/>
                </CellTemplate>
            </TemplateColumn>
            @if (hasDetailedEditor)
            {
                <TemplateColumn Title=""
                                Sortable="false">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="@Size.Small"
                                       OnClick="@(() => OpenDetails(context.Item))"/>
                    </CellTemplate>
                </TemplateColumn>
            }
        </Columns>

        <NoRecordsContent>
            <MudText>No species match the search.</MudText>
        </NoRecordsContent>

    </MudDataGrid>
}
