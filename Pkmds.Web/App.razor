@using Microsoft.AspNetCore.Components.Routing
@using MudBlazor
@using Pkmds.Rcl.Components.Layout
@using Pkmds.Rcl.Components.Pages
@using Pkmds.Rcl.Theming
@inject IJSRuntime JsRuntime
@inject IDialogService DialogService
@inject IAppState AppState

@* Mud providers live OUTSIDE the ErrorBoundary so dialogs/snackbars/popovers      *@
@* (and their themed styling) survive the ErrorBoundary firing. Without this, the *@
@* crash-report dialog would have no provider to render into when the child tree  *@
@* is unmounted, and would also lose theme CSS so it'd render unstyled.           *@
<MudThemeProvider @ref="@mudThemeProvider"
                  IsDarkMode="@isDarkMode"
                  Theme="@AppTheme.Default"/>
<MudPopoverProvider/>
<MudDialogProvider BackdropClick="false"/>
<MudSnackbarProvider/>

<ErrorBoundary @ref="errorBoundary">
    <ChildContent>
        <Router AppAssembly="@typeof(MainLayout).Assembly"
                NotFoundPage="@typeof(NotFound)">
            <Found Context="routeData">
                <RouteView RouteData="@routeData"
                           DefaultLayout="@typeof(MainLayout)"/>
                <FocusOnNavigate RouteData="@routeData"
                                 Selector="h1"/>
            </Found>
        </Router>
    </ChildContent>
    <ErrorContent Context="exception">
        <MudContainer MaxWidth="MaxWidth.Small"
                      Class="mt-8">
            <MudAlert Severity="Severity.Error"
                      Variant="Variant.Filled"
                      Class="mb-4">
                An unexpected error occurred.
            </MudAlert>
            <MudText Typo="Typo.body2"
                     Class="mb-4"
                     Style="word-break: break-word; font-family: monospace;">
                @exception.GetType().Name: @exception.Message
            </MudText>
            <MudStack Row
                      Spacing="2">
                <MudButton OnClick="@(() => errorBoundary?.Recover())"
                           Variant="Variant.Outlined"
                           Color="Color.Default">
                    Try Again
                </MudButton>
                <MudButton OnClick="@(() => ShowCrashReportDialog(exception))"
                           Variant="Variant.Filled"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.BugReport">
                    Report this bug
                </MudButton>
            </MudStack>
        </MudContainer>
    </ErrorContent>
</ErrorBoundary>
