<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>com.bondcodes.pkmds.spotlight</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>PkmdsSpotlight</string>
    <key>CFBundleShortVersionString</key>
    <string>0.0.1</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- CFPlugin wiring: maps the MDImporter type UUID to our factory function. -->
    <key>CFPlugInDynamicRegistration</key>
    <string>NO</string>
    <key>CFPlugInFactories</key>
    <dict>
        <!-- Factory UUID (arbitrary; must match CFPlugInTypes entry below). -->
        <key>853E355C-AE45-4218-B231-21E468EFBDC7</key>
        <string>MetadataImporterPluginFactory</string>
    </dict>
    <key>CFPlugInTypes</key>
    <dict>
        <!-- MDImporter plugin type UUID (Apple-defined). -->
        <key>8B08C4BF-415B-11D8-B3F9-0003936726FC</key>
        <array>
            <string>853E355C-AE45-4218-B231-21E468EFBDC7</string>
        </array>
    </dict>

    <!-- Document types that trigger this importer. -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Pokémon Save File</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.bondcodes.pkmds.save-file</string>
            </array>
        </dict>
    </array>

    <!--
        Declare the UTI here (not only in the host app) so that Spotlight maps
        .sav/.dat/.fla to com.bondcodes.pkmds.save-file when indexing.  The host
        app intentionally omits these extensions from its UTExportedTypeDeclarations
        because they are "prohibited" extensions that macOS will not dispatch to
        sandboxed Quick Look extensions via the extension-based UTI path.  By
        declaring them here and having the importer set kMDItemContentType in the
        Spotlight database, Finder uses the database value (our UTI) rather than the
        extension-based resolution, which allows our QL extension to be dispatched.
    -->
    <key>UTImportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.bondcodes.pkmds.save-file</string>
            <key>UTTypeDescription</key>
            <string>Pokémon Save File</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.data</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>sav</string>
                    <string>dat</string>
                    <string>fla</string>
                </array>
            </dict>
        </dict>
    </array>
</dict>
</plist>
